@model VinhKhanhFood.Admin.Models.DeviceHistoryViewModel

@{
    ViewData["Title"] = "Device History";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Lich su thiet bi su dung app</h2>
</div>

@if (TempData["Error"] is string errorMessage)
{
    <div class="alert alert-danger">@errorMessage</div>
}

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small">Dang online hien tai</div>
                <div class="fs-3 fw-bold">@Model.ActiveDevicesNow</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small">Hoat dong trong 24h</div>
                <div class="fs-3 fw-bold">@Model.ActiveDevicesLast24Hours</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small">Hoat dong trong thang nay</div>
                <div class="fs-3 fw-bold">@Model.ActiveDevicesThisMonth</div>
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <h5 class="card-title">Danh sach thiet bi / guid</h5>
        <table class="table table-bordered table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>ID</th>
                    <th>Username</th>
                    <th>Loai</th>
                    <th>Trang thai</th>
                    <th>Last seen (UTC)</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Devices.Count == 0)
                {
                    <tr>
                        <td colspan="5" class="text-center text-muted">Chua co du lieu thiet bi.</td>
                    </tr>
                }
                else
                {
                    @foreach (var device in Model.Devices)
                    {
                        <tr>
                            <td>@(string.IsNullOrWhiteSpace(device.DisplayId) ? device.Id.ToString() : device.DisplayId)</td>
                            <td>@device.Username</td>
                            <td>@(device.IsVirtual ? "guid" : "registered")</td>
                            <td>
                                @if (device.OnlineStatus == "Online")
                                {
                                    <span class="badge bg-success-subtle text-success border border-success-subtle">Online</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle">Offline</span>
                                }
                            </td>
                            <td>@(device.LastSeenUtc?.ToString("yyyy-MM-dd HH:mm:ss") ?? "-")</td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
