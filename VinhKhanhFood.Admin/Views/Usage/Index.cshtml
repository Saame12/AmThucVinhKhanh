@model VinhKhanhFood.Admin.Models.UsageDashboardViewModel

@{
    ViewData["Title"] = "Thong ke truy cap POI";
}

<style>
    .heatmap-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 12px;
    }

    .heatmap-tile {
        border-radius: 18px;
        padding: 16px;
        color: #111827;
        border: 1px solid rgba(0,0,0,.08);
        box-shadow: 0 8px 24px rgba(15, 23, 42, .08);
    }
</style>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Thong ke truy cap va nghe audio cua khach du lich</h2>
    <form method="get" class="d-flex gap-2">
        <select name="period" class="form-select">
            <option value="week" selected="@(Model.SelectedPeriod == "week")">Tuan</option>
            <option value="month" selected="@(Model.SelectedPeriod == "month")">Thang</option>
            <option value="year" selected="@(Model.SelectedPeriod == "year")">Nam</option>
        </select>
        <button type="submit" class="btn btn-primary">Xem</button>
    </form>
</div>

@if (TempData["Error"] is string errorMessage)
{
    <div class="alert alert-danger">@errorMessage</div>
}

<p class="text-muted">Khoang thoi gian dang xem: <strong>@Model.PeriodLabel</strong></p>

<div class="row g-3 mb-4">
    <div class="col-md-2">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small">Online hien tai</div>
                <div class="fs-3 fw-bold">@Model.ActiveDevicesNow</div>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small">Thiet bi 24h</div>
                <div class="fs-3 fw-bold">@Model.ActiveDevicesLast24Hours</div>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small">Thiet bi thang nay</div>
                <div class="fs-3 fw-bold">@Model.ActiveDevicesThisMonth</div>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small">Luot xem POI</div>
                <div class="fs-3 fw-bold">@Model.TotalTravelerViews</div>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small">Luot nghe audio</div>
                <div class="fs-3 fw-bold">@Model.TotalAudioPlays</div>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small">So POI co data</div>
                <div class="fs-3 fw-bold">@Model.DistinctPois</div>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small">Visitor tai POI</div>
                <div class="fs-3 fw-bold">@Model.VisitorsAtPoiNow</div>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small">Visitor giua 2 POI</div>
                <div class="fs-3 fw-bold">@Model.VisitorsBetweenPoisNow</div>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small">Nguoi dang nghe</div>
                <div class="fs-3 fw-bold">@Model.ActiveAudioListenersNow</div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-lg-6">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <h5 class="card-title">Visitor dang o tung POI</h5>
                <table class="table table-bordered table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>POI</th>
                            <th>Visitor online</th>
                        </tr>
                    </thead>
                    <tbody>
                    @if (Model.VisitorPresence.Count == 0)
                    {
                        <tr><td colspan="2" class="text-center text-muted">Chua co visitor nao dang o trong vung POI.</td></tr>
                    }
                    else
                    {
                        @foreach (var item in Model.VisitorPresence)
                        {
                            <tr>
                                <td>@item.PoiName (@item.PoiId)</td>
                                <td>@item.VisitorCount</td>
                            </tr>
                        }
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <h5 class="card-title">Visitor dang dung giua 2 POI</h5>
                <table class="table table-bordered table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Tuyen POI</th>
                            <th>Visitor</th>
                        </tr>
                    </thead>
                    <tbody>
                    @if (Model.BetweenPoiVisitors.Count == 0)
                    {
                        <tr><td colspan="2" class="text-center text-muted">Chua co visitor nao o trang thai BETWEEN_POIS.</td></tr>
                    }
                    else
                    {
                        @foreach (var item in Model.BetweenPoiVisitors)
                        {
                            <tr>
                                <td>@item.RouteLabel</td>
                                <td>@item.VisitorCount</td>
                            </tr>
                        }
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card shadow-sm h-100 border-success">
            <div class="card-body">
                <div class="text-muted small">POI xem nhieu nhat</div>
                <div class="fw-bold">@((Model.MostVisitedPoi?.PoiName) ?? "Chua co du lieu")</div>
                <div class="small text-success">@((Model.MostVisitedPoi?.VisitCount).GetValueOrDefault()) luot</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card shadow-sm h-100 border-warning">
            <div class="card-body">
                <div class="text-muted small">POI xem it nhat</div>
                <div class="fw-bold">@((Model.LeastVisitedPoi?.PoiName) ?? "Chua co du lieu")</div>
                <div class="small text-warning">@((Model.LeastVisitedPoi?.VisitCount).GetValueOrDefault()) luot</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card shadow-sm h-100 border-success">
            <div class="card-body">
                <div class="text-muted small">POI nghe nhieu nhat</div>
                <div class="fw-bold">@((Model.MostPlayedPoi?.PoiName) ?? "Chua co du lieu")</div>
                <div class="small text-success">@((Model.MostPlayedPoi?.VisitCount).GetValueOrDefault()) luot</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card shadow-sm h-100 border-warning">
            <div class="card-body">
                <div class="text-muted small">POI nghe it nhat</div>
                <div class="fw-bold">@((Model.LeastPlayedPoi?.PoiName) ?? "Chua co du lieu")</div>
                <div class="small text-warning">@((Model.LeastPlayedPoi?.VisitCount).GetValueOrDefault()) luot</div>
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <h5 class="card-title">Hang doi nghe audio theo POI</h5>
        @if (Model.LiveAudioQueues.Count == 0)
        {
            <div class="text-muted">Chua co visitor nao dang nghe audio trong 30 giay gan nhat.</div>
        }
        else
        {
            <div class="row g-3">
                @foreach (var queue in Model.LiveAudioQueues)
                {
                    <div class="col-lg-6">
                        <div class="border rounded-4 p-3 h-100">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <div class="fw-bold">@queue.PoiName (@queue.PoiId)</div>
                                <span class="badge bg-primary">@queue.ListenerCount nguoi nghe</span>
                            </div>
                            <table class="table table-sm table-bordered mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Queue</th>
                                        <th>Visitor</th>
                                        <th>Heartbeat</th>
                                    </tr>
                                </thead>
                                <tbody>
                                @foreach (var listener in queue.Listeners)
                                {
                                    <tr>
                                        <td>@listener.QueuePosition</td>
                                        <td>@listener.VisitorName</td>
                                        <td>@(listener.LastHeartbeatUtc?.ToLocalTime().ToString("dd/MM HH:mm:ss") ?? "-")</td>
                                    </tr>
                                }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <h5 class="card-title">Heatmap du lieu POI theo luot nghe audio</h5>
        @if (Model.HeatmapPoints.Count == 0)
        {
            <div class="text-muted">Chua co du lieu nghe audio de tao heatmap.</div>
        }
        else
        {
            <div class="heatmap-grid">
                @foreach (var point in Model.HeatmapPoints)
                {
                    var opacity = Math.Max(0.15, point.IntensityRatio);
                    <div class="heatmap-tile" style="background-color: rgba(249, 115, 22, @opacity.ToString(System.Globalization.CultureInfo.InvariantCulture));">
                        <div class="fw-bold">@point.PoiName</div>
                        <div class="small">POI ID: @point.PoiId</div>
                        <div class="small">Nghe: @point.Intensity</div>
                        <div class="small text-muted">Lat: @point.Latitude, Lng: @point.Longitude</div>
                    </div>
                }
            </div>
        }
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-lg-6">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <h5 class="card-title">Xep hang POI theo luot xem</h5>
                <table class="table table-bordered table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>#</th>
                            <th>POI</th>
                            <th>Luot xem</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.ViewRankings.Count == 0)
                        {
                            <tr><td colspan="3" class="text-center text-muted">Chua co du lieu.</td></tr>
                        }
                        else
                        {
                            @for (var i = 0; i < Model.ViewRankings.Count; i++)
                            {
                                var item = Model.ViewRankings[i];
                                <tr>
                                    <td>@(i + 1)</td>
                                    <td>@item.PoiName (@item.PoiId)</td>
                                    <td>@item.VisitCount</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <h5 class="card-title">Xep hang POI theo luot nghe audio</h5>
                <table class="table table-bordered table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>#</th>
                            <th>POI</th>
                            <th>Luot nghe</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.AudioRankings.Count == 0)
                        {
                            <tr><td colspan="3" class="text-center text-muted">Chua co du lieu.</td></tr>
                        }
                        else
                        {
                            @for (var i = 0; i < Model.AudioRankings.Count; i++)
                            {
                                var item = Model.AudioRankings[i];
                                <tr>
                                    <td>@(i + 1)</td>
                                    <td>@item.PoiName (@item.PoiId)</td>
                                    <td>@item.VisitCount</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <h5 class="card-title">Lich su hoat dong gan nhat</h5>
        <table class="table table-bordered table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>User</th>
                    <th>Action</th>
                    <th>POI</th>
                    <th>Role</th>
                    <th>Time</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.HistoryItems.Count == 0)
                {
                    <tr>
                        <td colspan="5" class="text-center text-muted">Chua co du lieu.</td>
                    </tr>
                }
                else
                {
                    @foreach (var item in Model.HistoryItems)
                    {
                        <tr>
                            <td>@item.UserName (@item.UserId)</td>
                            <td>@item.Action</td>
                            <td>@item.PoiName (@item.PoiId)</td>
                            <td>@item.Role</td>
                            <td>@item.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
