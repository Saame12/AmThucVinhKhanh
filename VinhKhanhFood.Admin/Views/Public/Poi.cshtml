@model VinhKhanhFood.Admin.Models.PublicPoiViewModel

@{
    ViewData["Title"] = Model.Name;
    Layout = null;
    var imageUrl = !string.IsNullOrWhiteSpace(Model.ImageUrl)
        ? (Model.ImageUrl.StartsWith("http", StringComparison.OrdinalIgnoreCase)
            ? Model.ImageUrl
            : $"/images/{Model.ImageUrl.TrimStart('/')}")
        : "https://placehold.co/960x720/F5F5F5/9CA3AF?text=POI+Image";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Vinh Khanh Food</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            padding: 20px;
        }
        .poi-container {
            max-width: 860px;
            margin: 0 auto;
            background: white;
            border-radius: 20px;
            overflow: hidden;
            box-shadow: 0 20px 60px rgba(0,0,0,0.25);
        }
        .poi-image {
            width: 100%;
            height: 380px;
            object-fit: cover;
        }
        .poi-content {
            padding: 30px;
        }
        .poi-title {
            font-size: 2rem;
            font-weight: bold;
            color: #1a202c;
            margin-bottom: 16px;
        }
        .poi-description {
            font-size: 1.05rem;
            line-height: 1.8;
            color: #4a5568;
            white-space: pre-wrap;
        }
        .feature-box {
            margin-top: 24px;
            padding: 18px;
            background: #f8fafc;
            border-radius: 14px;
            border: 1px solid #e2e8f0;
        }
        .audio-controls {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
            margin-top: 16px;
            align-items: center;
        }
        .audio-btn {
            border: none;
            border-radius: 999px;
            padding: 10px 20px;
            font-weight: 600;
            cursor: pointer;
        }
        .audio-btn.play {
            background: #2563eb;
            color: white;
        }
        .audio-btn.stop {
            background: #e2e8f0;
            color: #1e293b;
        }
        .audio-btn:disabled {
            opacity: 0.55;
            cursor: not-allowed;
        }
        .audio-status {
            font-size: 0.95rem;
            color: #475569;
        }
        .unlock-card {
            margin-top: 28px;
            padding: 24px;
            border-radius: 18px;
            background: #fff7ed;
            border: 1px solid #fed7aa;
        }
        .unlock-price {
            font-size: 2rem;
            font-weight: 700;
            color: #c2410c;
        }
        .demo-code {
            background: white;
            padding: 14px;
            border-radius: 10px;
            border: 1px dashed #fdba74;
            font-family: Consolas, monospace;
            font-size: 1rem;
            color: #9a3412;
        }
        .primary-btn {
            background: linear-gradient(135deg, #ea580c 0%, #f59e0b 100%);
            color: white;
            border: none;
            padding: 14px 28px;
            border-radius: 999px;
            font-weight: 600;
            cursor: pointer;
        }
        .open-app-btn {
            display: inline-block;
            margin-top: 16px;
            padding: 12px 24px;
            border-radius: 999px;
            background: #2563eb;
            color: white;
            text-decoration: none;
            font-weight: 600;
        }
        .open-app-btn:hover {
            color: white;
            background: #1d4ed8;
        }
    </style>
</head>
<body>
    <div class="container mb-3" style="max-width:860px;">
        <a href="/public" class="text-white text-decoration-none">← Quay lai danh sach</a>
    </div>

    <div class="poi-container">
        <img src="@imageUrl" alt="@Model.Name" class="poi-image" />

        <div class="poi-content">
            <h1 class="poi-title">@Model.Name</h1>

            @if (!string.IsNullOrWhiteSpace(Model.Description))
            {
                <div class="poi-description">@Model.Description</div>
            }

            <div class="feature-box">
                <strong>Noi dung co ban</strong>
                <div class="text-muted mt-2">
                    Ban co the xem mo ta POI tren web. Thanh toan 1 lan 10k de mo khoa day du chuc nang tren web public cho phien su dung nay.
                </div>
            </div>

            @if (Model.HasDefaultAudio)
            {
                <div class="feature-box">
                    <strong>Audio mac dinh</strong>
                    <div class="text-muted mt-2">
                        @if (Model.HasPaid)
                        {
                            <span>Ban da mo khoa web public. Co the nghe audio mac dinh ngay tai day.</span>
                        }
                        else
                        {
                            <span>Hoan tat thanh toan 10k de nghe audio mac dinh va dung day du tinh nang tren web public.</span>
                        }
                    </div>
                    <div class="audio-controls">
                        <button type="button"
                                id="playDefaultAudioButton"
                                class="audio-btn play"
                                onclick="playDefaultAudio()"
                                disabled="@(!Model.HasPaid)">
                            Phat audio
                        </button>
                        <button type="button"
                                id="stopDefaultAudioButton"
                                class="audio-btn stop"
                                onclick="stopDefaultAudio()"
                                disabled>
                            Dung audio
                        </button>
                        <div id="audioStatusLabel" class="audio-status">
                            @(Model.HasPaid ? "San sang phat audio mac dinh." : "Can mo khoa 10k de bat audio mac dinh.")
                        </div>
                    </div>
                </div>
            }

            @if (Model.HasPaid)
            {
                <div class="unlock-card" style="background:#ecfeff;border-color:#a5f3fc;">
                    <div class="fw-bold fs-5 text-success">Da thanh toan thanh cong</div>
                    <div class="text-muted mt-2">
                        Ban da mo khoa thanh cong cho web public. Bay gio co the nghe audio mac dinh va xem day du noi dung tren web.
                    </div>
                </div>
            }
            else
            {
                <div class="unlock-card">
                    <div class="fw-bold fs-4">Mo khoa toan bo chuc nang</div>
                    <div class="text-muted mt-2">
                        Thanh toan 1 lan de mo khoa toan bo chuc nang tren web public. Neu muon nghe audio guide trong app, nguoi dung se mo khoa 10k rieng trong app.
                    </div>

                    <div class="unlock-price mt-3">@Model.Amount.ToString("N0") VND</div>

                    <img src="@Model.PaymentQrImageUrl"
                         alt="Payment QR"
                         style="width:260px;height:260px;border-radius:14px;border:2px solid #fdba74;padding:10px;background:white;"
                         class="mt-3" />

                    <div class="demo-code mt-3">
                        Demo code: <strong>@Model.PaymentQrCode</strong><br />
                        Hoac dung ma nhanh: <strong>DEMO-10K</strong>
                    </div>

                    <input type="text"
                           id="paymentCodeInput"
                           class="form-control mt-3"
                           placeholder="Nhap ma thanh toan demo de mo khoa" />

                    <button class="primary-btn mt-3" onclick="verifyPayment()">Thanh toan @Model.Amount.ToString("N0") VND</button>
                </div>
            }
        </div>
    </div>

    <script>
        const defaultNarration = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Description ?? string.Empty));
        const hasPaid = @Model.HasPaid.ToString().ToLowerInvariant();
        let currentUtterance = null;

        function setAudioButtons(isPlaying) {
            const playButton = document.getElementById('playDefaultAudioButton');
            const stopButton = document.getElementById('stopDefaultAudioButton');
            if (!playButton || !stopButton) {
                return;
            }

            playButton.disabled = !hasPaid || isPlaying;
            stopButton.disabled = !isPlaying;
        }

        function setAudioStatus(message) {
            const label = document.getElementById('audioStatusLabel');
            if (label) {
                label.textContent = message;
            }
        }

        function stopDefaultAudio() {
            if (!('speechSynthesis' in window)) {
                setAudioStatus('Trinh duyet nay khong ho tro audio mac dinh.');
                return;
            }

            window.speechSynthesis.cancel();
            currentUtterance = null;
            setAudioButtons(false);
            setAudioStatus('Da dung audio mac dinh.');
        }

        function playDefaultAudio() {
            if (!hasPaid) {
                setAudioStatus('Can mo khoa 10k de bat audio mac dinh.');
                return;
            }

            if (!defaultNarration) {
                setAudioStatus('POI nay hien chua co noi dung audio mac dinh.');
                return;
            }

            if (!('speechSynthesis' in window)) {
                setAudioStatus('Trinh duyet nay khong ho tro audio mac dinh.');
                return;
            }

            stopDefaultAudio();

            currentUtterance = new SpeechSynthesisUtterance(defaultNarration);
            currentUtterance.lang = 'vi-VN';
            currentUtterance.onstart = () => {
                setAudioButtons(true);
                setAudioStatus('Dang phat audio mac dinh...');
            };
            currentUtterance.onend = () => {
                currentUtterance = null;
                setAudioButtons(false);
                setAudioStatus('Audio mac dinh da phat xong.');
            };
            currentUtterance.onerror = () => {
                currentUtterance = null;
                setAudioButtons(false);
                setAudioStatus('Khong the phat audio mac dinh luc nay.');
            };

            window.speechSynthesis.speak(currentUtterance);
        }

        async function verifyPayment() {
            const input = document.getElementById('paymentCodeInput');
            const code = input.value.trim();

            if (!code) {
                alert('Hay nhap ma thanh toan demo.');
                return;
            }

            const response = await fetch('/public/poi/@Model.PoiId/verify-payment', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({
                    poiId: @Model.PoiId,
                    transactionCode: code
                })
            });

            const result = await response.json();
            if (result.success) {
                window.location.href = result.redirectUrl;
                return;
            }

            alert(result.message || 'Khong the xac nhan thanh toan.');
        }

        const paymentCodeInput = document.getElementById('paymentCodeInput');
        if (paymentCodeInput) {
            paymentCodeInput.addEventListener('keypress', function (event) {
                if (event.key === 'Enter') {
                    verifyPayment();
                }
            });
        }

        window.addEventListener('beforeunload', stopDefaultAudio);
    </script>
</body>
</html>
