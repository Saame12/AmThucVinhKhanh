@model VinhKhanhFood.Admin.Models.PublicPoiViewModel

@{
    ViewData["Title"] = Model.Name;
    Layout = null;
    var imageUrl = !string.IsNullOrWhiteSpace(Model.ImageUrl)
        ? (Model.ImageUrl.StartsWith("http", StringComparison.OrdinalIgnoreCase)
            ? Model.ImageUrl
            : $"/images/{Model.ImageUrl.TrimStart('/')}")
        : "https://placehold.co/960x720/F5F5F5/9CA3AF?text=POI+Image";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Vinh Khanh Food</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            padding: 20px;
        }
        .poi-container {
            max-width: 860px;
            margin: 0 auto;
            background: white;
            border-radius: 20px;
            overflow: hidden;
            box-shadow: 0 20px 60px rgba(0,0,0,0.25);
        }
        .poi-image {
            width: 100%;
            height: 380px;
            object-fit: cover;
        }
        .poi-content {
            padding: 30px;
        }
        .poi-title {
            font-size: 2rem;
            font-weight: bold;
            color: #1a202c;
            margin-bottom: 16px;
        }
        .poi-description {
            font-size: 1.05rem;
            line-height: 1.8;
            color: #4a5568;
            white-space: pre-wrap;
        }
        .feature-box {
            margin-top: 24px;
            padding: 18px;
            background: #f8fafc;
            border-radius: 14px;
            border: 1px solid #e2e8f0;
        }
        .unlock-card {
            margin-top: 28px;
            padding: 24px;
            border-radius: 18px;
            background: #fff7ed;
            border: 1px solid #fed7aa;
        }
        .unlock-price {
            font-size: 2rem;
            font-weight: 700;
            color: #c2410c;
        }
        .demo-code {
            background: white;
            padding: 14px;
            border-radius: 10px;
            border: 1px dashed #fdba74;
            font-family: Consolas, monospace;
            font-size: 1rem;
            color: #9a3412;
        }
        .primary-btn {
            background: linear-gradient(135deg, #ea580c 0%, #f59e0b 100%);
            color: white;
            border: none;
            padding: 14px 28px;
            border-radius: 999px;
            font-weight: 600;
            cursor: pointer;
        }
        .open-app-btn {
            display: inline-block;
            margin-top: 16px;
            padding: 12px 24px;
            border-radius: 999px;
            background: #2563eb;
            color: white;
            text-decoration: none;
            font-weight: 600;
        }
        .open-app-btn:hover {
            color: white;
            background: #1d4ed8;
        }
    </style>
</head>
<body>
    <div class="container mb-3" style="max-width:860px;">
        <a href="/public" class="text-white text-decoration-none">← Quay lai danh sach</a>
    </div>

    <div class="poi-container">
        <img src="@imageUrl" alt="@Model.Name" class="poi-image" />

        <div class="poi-content">
            <h1 class="poi-title">@Model.Name</h1>

            @if (!string.IsNullOrWhiteSpace(Model.Description))
            {
                <div class="poi-description">@Model.Description</div>
            }

            <div class="feature-box">
                <strong>Noi dung co ban</strong>
                <div class="text-muted mt-2">
                    Ban co the xem mo ta POI tren web. De dung day du chuc nang trong app va nghe audio, hay mo khoa thiet bi voi 10k.
                </div>
            </div>

            @if (Model.HasPaid && Model.HasClaimToken)
            {
                <div class="unlock-card" style="background:#ecfeff;border-color:#a5f3fc;">
                    <div class="fw-bold fs-5 text-success">Da thanh toan thanh cong</div>
                    <div class="text-muted mt-2">
                        Thiet bi web da co ma kich hoat. Ban co the tiep tuc tren web hoac mo thang ung dung de claim token cho dien thoai nay.
                    </div>
                    <a href="@Model.OpenInAppUrl" class="open-app-btn">Mo trong app</a>
                    <div class="small text-muted mt-3">
                        Token demo: <code>@Model.ClaimToken</code>
                    </div>
                </div>
            }
            else
            {
                <div class="unlock-card">
                    <div class="fw-bold fs-4">Mo khoa toan bo chuc nang</div>
                    <div class="text-muted mt-2">
                        Thanh toan 1 lan de mo khoa app cho thiet bi nay. Sau khi thanh toan xong, bam <strong>Mo trong app</strong> de kich hoat tren dien thoai.
                    </div>

                    <div class="unlock-price mt-3">@Model.Amount.ToString("N0") VND</div>

                    <img src="@Model.PaymentQrImageUrl"
                         alt="Payment QR"
                         style="width:260px;height:260px;border-radius:14px;border:2px solid #fdba74;padding:10px;background:white;"
                         class="mt-3" />

                    <div class="demo-code mt-3">
                        Demo code: <strong>@Model.PaymentQrCode</strong><br />
                        Hoac dung ma nhanh: <strong>DEMO-10K</strong>
                    </div>

                    <input type="text"
                           id="paymentCodeInput"
                           class="form-control mt-3"
                           placeholder="Nhap ma thanh toan demo de mo khoa" />

                    <button class="primary-btn mt-3" onclick="verifyPayment()">Thanh toan @Model.Amount.ToString("N0") VND</button>
                </div>
            }
        </div>
    </div>

    <script>
        async function verifyPayment() {
            const input = document.getElementById('paymentCodeInput');
            const code = input.value.trim();

            if (!code) {
                alert('Hay nhap ma thanh toan demo.');
                return;
            }

            const response = await fetch('/public/poi/@Model.PoiId/verify-payment', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({
                    poiId: @Model.PoiId,
                    transactionCode: code
                })
            });

            const result = await response.json();
            if (result.success) {
                window.location.href = result.redirectUrl;
                return;
            }

            alert(result.message || 'Khong the xac nhan thanh toan.');
        }

        const paymentCodeInput = document.getElementById('paymentCodeInput');
        if (paymentCodeInput) {
            paymentCodeInput.addEventListener('keypress', function (event) {
                if (event.key === 'Enter') {
                    verifyPayment();
                }
            });
        }
    </script>
</body>
</html>
