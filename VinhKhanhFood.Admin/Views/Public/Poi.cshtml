@model VinhKhanhFood.Admin.Models.PublicPoiViewModel

@{
    ViewData["Title"] = Model.Name;
    Layout = null;
    var imageUrl = !string.IsNullOrWhiteSpace(Model.ImageUrl)
        ? (Model.ImageUrl.StartsWith("http", StringComparison.OrdinalIgnoreCase)
            ? Model.ImageUrl
            : $"/images/{Model.ImageUrl.TrimStart('/')}")
        : "https://placehold.co/960x720/F5F5F5/9CA3AF?text=POI+Image";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Vinh Khanh Food</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            padding: 20px;
        }
        .poi-container {
            max-width: 800px;
            margin: 0 auto;
            background: white;
            border-radius: 20px;
            overflow: hidden;
            box-shadow: 0 20px 60px rgba(0,0,0,0.3);
            position: relative;
        }
        .poi-image {
            width: 100%;
            height: 400px;
            object-fit: cover;
        }
        .poi-content {
            padding: 30px;
        }
        .poi-title {
            font-size: 2rem;
            font-weight: bold;
            color: #1a202c;
            margin-bottom: 20px;
        }
        .poi-description {
            font-size: 1.1rem;
            line-height: 1.8;
            color: #4a5568;
            white-space: pre-wrap;
        }
        .audio-player {
            margin-top: 30px;
            padding: 20px;
            background: #f7fafc;
            border-radius: 12px;
            border: 2px solid #e2e8f0;
        }
        .blur-overlay {
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            backdrop-filter: blur(20px);
            background: rgba(255, 255, 255, 0.7);
            z-index: 1000;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .payment-modal {
            background: white;
            padding: 40px;
            border-radius: 20px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.2);
            text-align: center;
            max-width: 500px;
            width: 90%;
        }
        .payment-qr {
            width: 300px;
            height: 300px;
            margin: 20px auto;
            border: 3px solid #667eea;
            border-radius: 12px;
            padding: 10px;
            background: white;
        }
        .payment-amount {
            font-size: 2.5rem;
            font-weight: bold;
            color: #667eea;
            margin: 20px 0;
        }
        .payment-instruction {
            color: #718096;
            margin-bottom: 20px;
            line-height: 1.6;
        }
        .demo-code {
            background: #f7fafc;
            padding: 15px;
            border-radius: 8px;
            border: 2px dashed #cbd5e0;
            margin-top: 20px;
            font-family: monospace;
            font-size: 1.1rem;
            color: #2d3748;
        }
        .verify-btn {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border: none;
            padding: 15px 40px;
            border-radius: 50px;
            font-size: 1.1rem;
            font-weight: 600;
            cursor: pointer;
            margin-top: 20px;
            transition: transform 0.2s;
        }
        .verify-btn:hover {
            transform: scale(1.05);
        }
        .verify-btn:disabled {
            opacity: 0.6;
            cursor: not-allowed;
        }
        .header {
            max-width: 800px;
            margin: 0 auto 20px;
        }
        .header a {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 10px 20px;
            background: rgba(255, 255, 255, 0.2);
            border-radius: 50px;
            transition: background 0.3s;
        }
        .header a:hover {
            background: rgba(255, 255, 255, 0.3);
        }
    </style>
</head>
<body>
    <div class="header">
        <a href="/public" style="color: white; text-decoration: none; display: inline-block; margin-bottom: 20px;">
            ← Quay lại danh sách
        </a>
    </div>

    <div class="poi-container">
        <img src="@imageUrl" alt="@Model.Name" class="poi-image" />

        <div class="poi-content">
            <h1 class="poi-title">@Model.Name</h1>

            @if (!string.IsNullOrWhiteSpace(Model.Description))
            {
                <div class="poi-description">@Model.Description</div>
            }

            <div class="audio-player">
                <div class="d-flex align-items-center">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" class="me-2" viewBox="0 0 16 16">
                        <path d="M11.536 14.01A8.473 8.473 0 0 0 14.026 8a8.473 8.473 0 0 0-2.49-6.01l-.708.707A7.476 7.476 0 0 1 13.025 8c0 2.071-.84 3.946-2.197 5.303l.708.707z"/>
                        <path d="M10.121 12.596A6.48 6.48 0 0 0 12.025 8a6.48 6.48 0 0 0-1.904-4.596l-.707.707A5.483 5.483 0 0 1 11.025 8a5.483 5.483 0 0 1-1.61 3.89l.706.706z"/>
                        <path d="M8.707 11.182A4.486 4.486 0 0 0 10.025 8a4.486 4.486 0 0 0-1.318-3.182L8 5.525A3.489 3.489 0 0 1 9.025 8 3.49 3.49 0 0 1 8 10.475l.707.707zM6.717 3.55A.5.5 0 0 1 7 4v8a.5.5 0 0 1-.812.39L3.825 10.5H1.5A.5.5 0 0 1 1 10V6a.5.5 0 0 1 .5-.5h2.325l2.363-1.89a.5.5 0 0 1 .529-.06z"/>
                    </svg>
                    <strong>Audio Guide Available</strong>
                </div>
                <p class="text-muted mb-0 mt-2 small">Text-to-speech narration will play the description above</p>
            </div>
        </div>

        @if (!Model.HasPaid)
        {
            <div class="blur-overlay">
                <div class="payment-modal">
                    <h2 style="color: #1a202c; margin-bottom: 10px;">🔒 Mua Gói 5 Năm</h2>
                    <p class="payment-instruction">
                        Thanh toán <strong>1 lần duy nhất</strong> để truy cập <strong>TẤT CẢ POIs</strong> trong <strong>5 năm</strong>
                    </p>

                    <div class="payment-amount">50,000 VND</div>
                    <div class="text-muted mb-3">
                        <small>✨ Truy cập không giới hạn tất cả điểm POI</small><br/>
                        <small>⏰ Hiệu lực: 5 năm (đến 29/04/2031)</small>
                    </div>

                    <img src="@Model.PaymentQrImageUrl" alt="Payment QR Code" class="payment-qr" />

                    <div class="demo-code">
                        <strong>Demo Mode:</strong><br/>
                        Payment Code: <span style="color: #667eea;">@Model.PaymentQrCode</span><br/>
                        <small class="text-muted">Hoặc dùng: <strong>DEMO-5YEAR</strong></small>
                    </div>

                    <input type="text" id="paymentCodeInput" class="form-control mt-3" placeholder="Nhập mã thanh toán để kích hoạt" />

                    <button class="verify-btn" onclick="verifyPayment()">
                        Kích Hoạt Gói 5 Năm
                    </button>

                    <p class="text-muted small mt-3">
                        Trong production, tích hợp với Momo, VNPay, hoặc chuyển khoản ngân hàng
                    </p>
                </div>
            </div>
        }
    </div>

    <script>
        async function verifyPayment() {
            const input = document.getElementById('paymentCodeInput');
            const code = input.value.trim();
            const btn = document.querySelector('.verify-btn');

            if (!code) {
                alert('Please enter a payment code');
                return;
            }

            btn.disabled = true;
            btn.textContent = 'Verifying...';

            try {
                const response = await fetch('/public/poi/@Model.PoiId/verify-payment', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        poiId: @Model.PoiId,
                        transactionCode: code
                    })
                });

                const result = await response.json();

                if (result.success) {
                    window.location.href = result.redirectUrl;
                } else {
                    alert(result.message || 'Invalid payment code');
                    btn.disabled = false;
                    btn.textContent = 'Verify Payment';
                }
            } catch (error) {
                alert('Verification failed. Please try again.');
                btn.disabled = false;
                btn.textContent = 'Verify Payment';
            }
        }

        // Allow Enter key to submit
        document.getElementById('paymentCodeInput').addEventListener('keypress', function(e) {
            if (e.key === 'Enter') {
                verifyPayment();
            }
        });
    </script>
</body>
</html>
