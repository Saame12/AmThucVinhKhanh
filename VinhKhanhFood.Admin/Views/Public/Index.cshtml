@model List<VinhKhanhFood.API.Models.FoodLocation>

@{
    ViewData["Title"] = "Vinh Khanh Food - Public Guide";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Arial, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            padding: 20px;
        }
        .header {
            text-align: center;
            color: white;
            margin-bottom: 30px;
        }
        .header h1 {
            font-size: 2.4rem;
            font-weight: 700;
            margin-bottom: 10px;
        }
        .header p {
            font-size: 1.05rem;
            opacity: 0.92;
        }
        .header-card {
            background: rgba(255,255,255,0.18);
            padding: 14px 18px;
            border-radius: 14px;
            max-width: 680px;
            margin: 20px auto 0;
        }
        .poi-grid {
            max-width: 1200px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 20px;
        }
        .poi-card {
            background: white;
            border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 10px 30px rgba(0,0,0,0.2);
            text-decoration: none;
            color: inherit;
            transition: transform 0.25s ease, box-shadow 0.25s ease;
        }
        .poi-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 14px 36px rgba(0,0,0,0.28);
        }
        .poi-image {
            width: 100%;
            height: 200px;
            object-fit: cover;
        }
        .poi-content {
            padding: 18px;
        }
        .poi-name {
            font-size: 1.2rem;
            font-weight: 700;
            color: #1f2937;
            margin-bottom: 8px;
        }
        .poi-description {
            color: #6b7280;
            line-height: 1.6;
            display: -webkit-box;
            -webkit-line-clamp: 3;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }
        .poi-badge {
            display: inline-block;
            margin-top: 12px;
            padding: 5px 12px;
            border-radius: 999px;
            background: #eff6ff;
            color: #2563eb;
            font-size: 0.85rem;
            font-weight: 600;
        }
    </style>
</head>
<body>
    <div class="header">
        <h1>Vinh Khanh Food Public Guide</h1>
        <p>Vao he thong bang QR Public, xem mo ta co ban va mo khoa 10k de dung day du chuc nang trong app.</p>
        @if (ViewBag.HasSubscription == true)
        {
            <div class="header-card">
                <strong>Da thanh toan thanh cong.</strong>
                Thiet bi web nay dang co quyen mo khoa den @ViewBag.SubscriptionEndDate?.ToString("dd/MM/yyyy")
            </div>
        }
        else
        {
            <div class="header-card">
                Thanh toan <strong>10.000 VND</strong> tren trang POI bat ky de mo khoa day du chuc nang tren web public. Neu muon nghe audio guide trong app, vui long mo khoa rieng trong app.
            </div>
        }
    </div>

    <div class="poi-grid">
        @foreach (var poi in Model)
        {
            var imageUrl = !string.IsNullOrWhiteSpace(poi.ImageUrl)
                ? (poi.ImageUrl.StartsWith("http", StringComparison.OrdinalIgnoreCase)
                    ? poi.ImageUrl
                    : $"/images/{poi.ImageUrl.TrimStart('/')}")
                : "https://placehold.co/600x400/F5F5F5/9CA3AF?text=POI+Image";

            <a href="/public/poi/@poi.Id" class="poi-card">
                <img src="@imageUrl"
                     alt="@poi.Name"
                     class="poi-image"
                     onerror="this.src='https://placehold.co/600x400/F5F5F5/9CA3AF?text=POI+Image'; this.onerror=null;" />
                <div class="poi-content">
                    <div class="poi-name">@poi.Name</div>
                    @if (!string.IsNullOrWhiteSpace(poi.Description))
                    {
                        <div class="poi-description">@poi.Description</div>
                    }
                    <span class="poi-badge">Mo ta co ban + mo khoa tren app</span>
                </div>
            </a>
        }
    </div>
</body>
</html>
