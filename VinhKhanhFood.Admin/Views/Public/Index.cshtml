@model List<VinhKhanhFood.API.Models.FoodLocation>

@{
    ViewData["Title"] = "Vinh Khanh Food - Discover Local Cuisine";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            padding: 20px;
        }
        .header {
            text-align: center;
            color: white;
            margin-bottom: 30px;
        }
        .header h1 {
            font-size: 2.5rem;
            font-weight: bold;
            margin-bottom: 10px;
            text-shadow: 0 2px 10px rgba(0,0,0,0.2);
        }
        .header p {
            font-size: 1.1rem;
            opacity: 0.9;
        }
        .poi-grid {
            max-width: 1200px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 20px;
        }
        .poi-card {
            background: white;
            border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 10px 30px rgba(0,0,0,0.2);
            transition: transform 0.3s, box-shadow 0.3s;
            cursor: pointer;
            text-decoration: none;
            color: inherit;
            display: block;
        }
        .poi-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 40px rgba(0,0,0,0.3);
        }
        .poi-image {
            width: 100%;
            height: 200px;
            object-fit: cover;
            background: linear-gradient(135deg, #f5f5f5 0%, #e0e0e0 100%);
        }
        .poi-content {
            padding: 20px;
        }
        .poi-name {
            font-size: 1.3rem;
            font-weight: bold;
            color: #1a202c;
            margin-bottom: 10px;
        }
        .poi-description {
            font-size: 0.95rem;
            color: #718096;
            line-height: 1.6;
            display: -webkit-box;
            -webkit-line-clamp: 3;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }
        .poi-badge {
            display: inline-block;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 5px 12px;
            border-radius: 20px;
            font-size: 0.85rem;
            margin-top: 10px;
        }
        .empty-state {
            text-align: center;
            color: white;
            padding: 60px 20px;
        }
        .empty-state h2 {
            font-size: 2rem;
            margin-bottom: 10px;
        }
    </style>
</head>
<body>
    <div class="header">
        <h1>🍜 Vinh Khanh Food</h1>
        <p>Khám phá ẩm thực địa phương với hướng dẫn âm thanh</p>
        @if (ViewBag.HasSubscription == true)
        {
            <div style="background: rgba(255,255,255,0.2); padding: 15px; border-radius: 12px; margin-top: 20px; max-width: 600px; margin-left: auto; margin-right: auto;">
                <div style="font-size: 1.2rem; font-weight: bold; margin-bottom: 5px;">
                    ✅ Gói 5 Năm Đã Kích Hoạt
                </div>
                <div style="font-size: 0.95rem; opacity: 0.9;">
                    Bạn có thể truy cập tất cả POIs đến: @ViewBag.SubscriptionEndDate?.ToString("dd/MM/yyyy")
                </div>
            </div>
        }
        else
        {
            <div style="background: rgba(255,255,255,0.2); padding: 15px; border-radius: 12px; margin-top: 20px; max-width: 600px; margin-left: auto; margin-right: auto;">
                <div style="font-size: 1rem; opacity: 0.9;">
                    💡 Mua gói 5 năm để truy cập không giới hạn tất cả POIs
                </div>
            </div>
        }
    </div>

    @if (Model.Any())
    {
        <div class="poi-grid">
            @foreach (var poi in Model)
            {
                var imageUrl = !string.IsNullOrWhiteSpace(poi.ImageUrl)
                    ? (poi.ImageUrl.StartsWith("http", StringComparison.OrdinalIgnoreCase)
                        ? poi.ImageUrl
                        : $"/images/{poi.ImageUrl.TrimStart('/')}")
                    : "https://placehold.co/600x400/F5F5F5/9CA3AF?text=POI+Image";

                <a href="/public/poi/@poi.Id" class="poi-card">
                    <img src="@imageUrl"
                         alt="@poi.Name"
                         class="poi-image"
                         onerror="this.src='https://placehold.co/600x400/F5F5F5/9CA3AF?text=POI+Image'; this.onerror=null;" />
                    <div class="poi-content">
                        <div class="poi-name">@poi.Name</div>
                        @if (!string.IsNullOrWhiteSpace(poi.Description))
                        {
                            <div class="poi-description">@poi.Description</div>
                        }
                        <span class="poi-badge">🎧 Audio Guide Available</span>
                    </div>
                </a>
            }
        </div>
    }
    else
    {
        <div class="empty-state">
            <h2>📍 Chưa có điểm POI nào</h2>
            <p>Hiện tại chưa có địa điểm nào được công khai. Vui lòng quay lại sau!</p>
        </div>
    }

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
