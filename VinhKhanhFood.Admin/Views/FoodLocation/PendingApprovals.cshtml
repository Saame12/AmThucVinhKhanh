@{
    ViewData["Title"] = "Duyệt POI (Quán Ăn)";
}

<div class="container-fluid mt-4">
    <h2>🍴 Duyệt POI (Quán Ăn)</h2>
    <hr />

    <ul class="nav nav-tabs mb-4">
        <li class="nav-item">
            <a class="nav-link active" id="pending-tab" data-tab="pending" onclick="switchTab('pending')">
                ⏳ Chờ Duyệt
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link" id="approved-tab" data-tab="approved" onclick="switchTab('approved')">
                ✅ Đã Duyệt
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link" id="rejected-tab" data-tab="rejected" onclick="switchTab('rejected')">
                ❌ Từ Chối
            </a>
        </li>
    </ul>

    <div id="poiContainer" class="row">
        <div class="col-md-12 text-center">
            <p class="text-muted">Đang tải dữ liệu...</p>
        </div>
    </div>
</div>

<!-- Modal xem chi tiết -->
<div class="modal fade" id="detailsModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Chi Tiết POI</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="detailsBody">
                Đang tải...
            </div>
            <div class="modal-footer" id="detailsFooter">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>

<script>
    const API_URL = 'http://localhost:5020/api';
    let currentTab = 'pending';

    document.addEventListener('DOMContentLoaded', function() {
        loadPOIs('pending');
    });

    function switchTab(tab) {
        currentTab = tab;
        
        // Update UI
        document.querySelectorAll('[data-tab]').forEach(el => el.classList.remove('active'));
        document.getElementById(tab + '-tab').classList.add('active');
        
        loadPOIs(tab);
    }

    function loadPOIs(status) {
        const url = status === 'pending' 
            ? `${API_URL}/admin/pending-foodlocations`
            : `${API_URL}/admin/foodlocations/${status.charAt(0).toUpperCase() + status.slice(1)}`;

        fetch(url)
            .then(response => response.json())
            .then(data => {
                const container = document.getElementById('poiContainer');

                if (!data || data.length === 0) {
                    container.innerHTML = `
                        <div class="col-md-12">
                            <div class="alert alert-info">Không có POI nào ở trạng thái này</div>
                        </div>
                    `;
                    return;
                }

                let html = '';
                data.forEach(poi => {
                    const statusBadge = getStatusBadge(poi.status);
                    const statusColor = poi.status === 'Approved' ? 'success' : 
                                       poi.status === 'Pending' ? 'warning' : 'danger';
                    
                    html += `
                        <div class="col-md-6 mb-4">
                            <div class="card border-${statusColor}">
                                <div class="card-header bg-${statusColor} text-white">
                                    <h5 class="mb-0">${poi.name}</h5>
                                </div>
                                <div class="card-body">
                                    <p><strong>📝 Mô Tả:</strong> ${poi.description || 'N/A'}</p>
                                    <p><strong>👤 Chủ:</strong> ${poi.owner?.fullName || 'N/A'}</p>
                                    <p><strong>📍 Vị Trí:</strong> ${poi.latitude.toFixed(4)}, ${poi.longitude.toFixed(4)}</p>
                                    <p><strong>📅 Ngày Đăng:</strong> ${new Date(poi.createdDate).toLocaleDateString('vi-VN')}</p>
                                </div>
                                <div class="card-footer">
                                    <button class="btn btn-sm btn-info" onclick="viewDetails(${poi.id})">👁️ Chi Tiết</button>
                                    ${poi.status === 'Pending' ? `
                                        <button class="btn btn-sm btn-success" onclick="approvePOI(${poi.id})">✅ Duyệt</button>
                                        <button class="btn btn-sm btn-danger" onclick="rejectPOI(${poi.id})">❌ Từ Chối</button>
                                    ` : ''}
                                </div>
                            </div>
                        </div>
                    `;
                });

                container.innerHTML = html;
            })
            .catch(error => {
                console.error('Error:', error);
                document.getElementById('poiContainer').innerHTML = `
                    <div class="col-md-12">
                        <div class="alert alert-danger">❌ Không thể tải danh sách</div>
                    </div>
                `;
            });
    }

    function getStatusBadge(status) {
        switch(status) {
            case 'Approved':
                return '<span class="badge bg-success">✅ Đã Duyệt</span>';
            case 'Pending':
                return '<span class="badge bg-warning">⏳ Chờ Duyệt</span>';
            case 'Rejected':
                return '<span class="badge bg-danger">❌ Từ Chối</span>';
            default:
                return '<span class="badge bg-secondary">?</span>';
        }
    }

    function viewDetails(poiId) {
        fetch(`${API_URL}/food/${poiId}`)
            .then(response => response.json())
            .then(poi => {
                let html = `
                    <div>
                        <h6>📍 Thông Tin POI</h6>
                        <p><strong>Tên:</strong> ${poi.name}</p>
                        <p><strong>Mô Tả VN:</strong> ${poi.description || 'N/A'}</p>
                        <p><strong>Mô Tả EN:</strong> ${poi.description_EN || 'N/A'}</p>
                        <p><strong>Vị Trí:</strong> ${poi.latitude.toFixed(4)}, ${poi.longitude.toFixed(4)}</p>
                        <p><strong>Hình Ảnh:</strong> ${poi.imageUrl ? `<a href="${poi.imageUrl}" target="_blank">Xem</a>` : 'N/A'}</p>
                        
                        <hr>
                        <h6>👤 Chủ Hàng</h6>
                        <p><strong>Tên:</strong> ${poi.owner?.fullName || 'N/A'}</p>
                        <p><strong>Quán:</strong> ${poi.owner?.businessName || 'N/A'}</p>
                        <p><strong>SĐT:</strong> ${poi.owner?.phoneNumber || 'N/A'}</p>
                    </div>
                `;
                document.getElementById('detailsBody').innerHTML = html;
                new bootstrap.Modal(document.getElementById('detailsModal')).show();
            });
    }

    function approvePOI(poiId) {
        if (!confirm('Duyệt POI này?')) return;

        fetch(`${API_URL}/admin/approve-foodlocation/${poiId}`, { method: 'POST' })
            .then(response => {
                if (response.ok) {
                    alert('✅ Đã duyệt!');
                    loadPOIs(currentTab);
                } else {
                    alert('❌ Lỗi!');
                }
            });
    }

    function rejectPOI(poiId) {
        const reason = prompt('Nhập lý do từ chối:');
        if (!reason) return;

        fetch(`${API_URL}/admin/reject-foodlocation/${poiId}`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ reason })
        })
        .then(response => {
            if (response.ok) {
                alert('✅ Đã từ chối!');
                loadPOIs(currentTab);
            } else {
                alert('❌ Lỗi!');
            }
        });
    }
</script>
