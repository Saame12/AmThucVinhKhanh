@model VinhKhanhFood.API.Models.FoodLocation

@{
    ViewData["Title"] = "QR Audio Guide";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h2 class="mb-1">QR Audio Guide cua POI</h2>
            <div class="text-muted">@Model.Name</div>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
    </div>

    <div class="row g-4">
        <div class="col-lg-5">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body text-center">
                    <img src="@Model.QrCodeImageUrl"
                         alt="@Model.QrCodeLabel"
                         class="img-fluid rounded"
                         style="max-width: 320px;" />
                    <div class="mt-3 fw-bold fs-5">@Model.QrCodeLabel</div>
                    <div class="small text-muted mt-1">Quet ma nay de mo chi tiet POI va phat audio mac dinh trong app.</div>
                </div>
            </div>
        </div>

        <div class="col-lg-7">
            <div class="card shadow-sm border-0 mb-3">
                <div class="card-body">
                    <h5 class="mb-3">Thong tin QR Audio</h5>
                    <div class="mb-2">
                        <div class="text-muted small">Deep link cua app</div>
                        <code>@Model.QrAudioUri</code>
                    </div>
                    <div class="mb-2">
                        <div class="text-muted small">Ma nhap thu cong</div>
                        <code>@Model.QrManualCode</code>
                    </div>
                    <div>
                        <div class="text-muted small">Audio mac dinh</div>
                        @if (Model.HasDefaultAudio)
                        {
                            <span class="badge bg-success">San sang</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Chua co noi dung audio</span>
                        }
                    </div>
                </div>
            </div>

            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <h5 class="mb-3">Cach su dung</h5>
                    <ol class="mb-0">
                        <li>In hoac dan QR nay tai diem POI.</li>
                        <li>Khach mo app va quet QR tai trang Scan QR.</li>
                        <li>App mo thang trang chi tiet cua POI.</li>
                        <li>Audio mac dinh se tu dong phat neu POI co mo ta.</li>
                        <li>Nguoi dung co the nhap ma <strong>@Model.QrManualCode</strong> de test thay cho camera.</li>
                    </ol>
                </div>
            </div>
        </div>
    </div>
</div>
