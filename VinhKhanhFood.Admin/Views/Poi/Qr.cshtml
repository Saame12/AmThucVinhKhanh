@model VinhKhanhFood.API.Models.FoodLocation

@{
    ViewData["Title"] = "POI QR";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h2 class="mb-1">🔳 QR nghe audio</h2>
            <div class="text-muted">@Model.Name - @Model.QrCodeLabel</div>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
    </div>

    <div class="row g-4">
        <div class="col-lg-5">
            <div class="card shadow-sm border-0">
                <div class="card-body text-center">
                    <img src="@Model.QrCodeImageUrl"
                         alt="@Model.QrCodeLabel"
                         class="img-fluid rounded"
                         style="max-width: 320px;" />
                    <div class="mt-3 fw-bold">@Model.QrCodeLabel</div>
                    <div class="text-muted small">@Model.QrAudioUri</div>
                </div>
            </div>
        </div>

        <div class="col-lg-7">
            <div class="card shadow-sm border-0 mb-3">
                <div class="card-body">
                    <h5>Audio mặc định</h5>
                    <p class="text-muted mb-2">Khi user quét QR trong app hoặc bằng điện thoại có hỗ trợ deep link, app sẽ mở đúng POI này và phát audio mặc định từ mô tả.</p>
                    <div>
                        @if (Model.HasDefaultAudio)
                        {
                            <span class="badge bg-success">Ready</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Missing description</span>
                        }
                    </div>
                </div>
            </div>

            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <h5>Audio chuyên nghiệp</h5>
                    <p class="text-muted mb-2">Nếu owner đã upload file audio, app có thể hiển thị thêm mục audio chuyên nghiệp riêng.</p>
                    <div>
                        @if (Model.HasProfessionalAudio)
                        {
                            <span class="badge bg-warning text-dark">Professional audio uploaded</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">No professional audio yet</span>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
