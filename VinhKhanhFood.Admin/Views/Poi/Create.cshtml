@model VinhKhanhFood.API.Models.FoodLocation

@{
    ViewData["Title"] = "Create New POI";
}

<div class="container mt-4">
    <h2 class="mb-4">➕ Add New Food Location</h2>

    <form asp-action="Create" enctype="multipart/form-data" method="post">
        <div class="row">
            <div class="col-md-7">
                <div class="card p-3 shadow-sm mb-3">
                    <h5 class="text-primary border-bottom pb-2">Basic Information</h5>

                    <div class="mb-3">
                        <label class="form-label">Location Name (Vietnamese)</label>
                        <input name="Name" class="form-control" required placeholder="Ví dụ: Ốc Thảo" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Location Name (English)</label>
                        <input name="Name_EN" class="form-control" placeholder="Example: Thao Snail Restaurant" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Location Name (Chinese)</label>
                        <input name="Name_ZH" class="form-control" placeholder="示例：涛螺餐厅" />
                    </div>

                    <div class="row">
                        <div class="col">
                            <label class="form-label">Latitude</label>
                            <input name="Latitude" class="form-control" placeholder="10.762..." />
                        </div>
                        <div class="col">
                            <label class="form-label">Longitude</label>
                            <input name="Longitude" class="form-control" placeholder="106.682..." />
                        </div>
                    </div>

                    <div class="mt-3">
                        <label class="form-label">Main Image</label>
                        <input type="file" name="imageFile" class="form-control" accept="image/*" />
                    </div>
                </div>
            </div>

            <div class="col-md-5">
                <div class="card bg-light p-3 shadow-sm border-0 mb-3">
                    <h5 class="text-success border-bottom pb-2"><i class="bi bi-soundwave"></i> Default Audio</h5>
                    <p class="text-muted small mb-3">Owner chỉ cần nhập mô tả. App sẽ dùng phần mô tả này làm audio mặc định bằng TTS khi user mở POI hoặc quét QR.</p>

                    <div class="mb-3">
                        <label>Mô tả (Vietnamese)</label>
                        <textarea name="Description" class="form-control" rows="3"></textarea>
                    </div>

                    <div class="mb-3">
                        <label>Description (English)</label>
                        <textarea name="Description_EN" class="form-control" rows="3"></textarea>
                    </div>

                    <div class="mb-3">
                        <label>描述 (Chinese)</label>
                        <textarea name="Description_ZH" class="form-control" rows="3"></textarea>
                    </div>
                </div>

                <div class="card bg-light p-3 shadow-sm border-0">
                    <h5 class="text-warning border-bottom pb-2"><i class="bi bi-stars"></i> Professional Audio</h5>
                    <p class="text-muted small mb-3">Nếu owner tự upload audio thì audio này sẽ được hiểu là audio chuyên nghiệp và có thể khóa quyền nghe trong app.</p>

                    <div class="mb-3">
                        <label class="fw-bold">🎧 Tiếng Việt</label>
                        <input type="file" name="audioViFile" class="form-control" accept="audio/*" />
                    </div>

                    <div class="mb-3">
                        <label class="fw-bold">🎧 English</label>
                        <input type="file" name="audioEnFile" class="form-control" accept="audio/*" />
                    </div>

                    <div class="mb-3">
                        <label class="fw-bold">🎧 中文</label>
                        <input type="file" name="audioZhFile" class="form-control" accept="audio/*" />
                    </div>

                    <div class="alert alert-info py-2 mb-0">
                        <small><i class="bi bi-info-circle"></i> Chấp nhận .mp3, .wav. QR của POI sẽ luôn mở audio mặc định.</small>
                    </div>
                </div>
            </div>
        </div>

        <div class="mt-4 border-top pt-3 text-end">
            <a asp-action="Index" class="btn btn-secondary me-2">Cancel</a>
            <button type="submit" class="btn btn-success px-5 shadow">Save POI</button>
        </div>
    </form>
</div>
