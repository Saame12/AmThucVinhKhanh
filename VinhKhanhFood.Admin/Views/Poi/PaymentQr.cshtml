@model VinhKhanhFood.Admin.Models.PoiPaymentQrViewModel

@{
    ViewData["Title"] = "Payment QR";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h2 class="mb-1">Payment QR cua POI</h2>
            <div class="text-muted">@Model.Poi.Name</div>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
    </div>

    <div class="row g-4">
        <div class="col-lg-5">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body text-center">
                    <img src="@Model.QrImageUrl"
                         alt="@Model.QrCodeLabel"
                         class="img-fluid rounded"
                         style="max-width: 320px;" />
                    <div class="mt-3 fw-bold fs-5">@Model.FixedAmount.ToString("N0") VND</div>
                    <div class="small text-muted">@Model.QrCodeLabel</div>
                </div>
            </div>
        </div>

        <div class="col-lg-7">
            <div class="card shadow-sm border-0 mb-3">
                <div class="card-body">
                    <h5 class="mb-3">Thong tin public QR Payment</h5>
                    @if (Model.IsLocalDemoUrl)
                    {
                        <div class="alert alert-warning py-2">
                            Dang o che do demo noi bo. QR hien tai mo trang public local cua web admin, khong can deploy that.
                        </div>
                    }
                    <div class="mb-2">
                        <div class="text-muted small">Public page</div>
                        <code>@Model.PublicPaymentUrl</code>
                    </div>
                    <div class="mb-2">
                        <div class="text-muted small">Gia co dinh moi lan quet</div>
                        <strong>@Model.FixedAmount.ToString("N0") VND</strong>
                    </div>
                    <div class="mb-2">
                        <div class="text-muted small">Diem den</div>
                        <strong>@Model.Poi.Name</strong>
                    </div>
                    <div>
                        <span class="badge bg-primary">Public Web QR</span>
                        <span class="badge bg-secondary">Chi mo khoa audio sau thanh toan</span>
                    </div>
                    <div class="mt-3">
                        <a href="@Model.PublicPaymentUrl" target="_blank" rel="noopener noreferrer" class="btn btn-sm btn-success">
                            Mo trang demo ngay
                        </a>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <h5 class="mb-3">Logic hoat dong</h5>
                    <ol class="mb-0">
                        <li>Khach quet QR tu nguon ben ngoai se mo trang web cong khai cua POI nay.</li>
                        <li>Trang public hien thong tin mo ta mien phi, chua cho nghe audio.</li>
                        <li>Chi sau khi thanh toan mock <strong>10.000 VND</strong>, tat ca audio cua POI moi duoc mo khoa.</li>
                        <li>Giao dich thanh cong duoc luu vao <strong>QR Payment Dashboard</strong>.</li>
                    </ol>
                </div>
            </div>
        </div>
    </div>
</div>
