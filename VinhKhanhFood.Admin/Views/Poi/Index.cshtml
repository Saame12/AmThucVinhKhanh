@model IEnumerable<VinhKhanhFood.API.Models.FoodLocation>

<div class="container-fluid pt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>📍 <loc key="Manage POI" /></h2>
        <a asp-action="Create" class="btn btn-primary shadow-sm">
            <i class="bi bi-plus-circle"></i> Add New Location
        </a>
    </div>

    <div class="card shadow border-0">
        <div class="card-body">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Status</th>
                        <th>Image</th>
                        <th>Name (VN)</th>
                        <th>Coordinates</th>
                        <th>Audio</th>
                        <th>QR</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <span class="badge
                                    @(item.Status == "Approved" ? "bg-success" :
                                      item.Status == "Pending" ? "bg-warning text-dark" : "bg-danger")">
                                    @item.Status
                                </span>
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(item.ImageUrl))
                                {
                                    var apiUrl = "http://localhost:5020/images/";
                                    <img src="@(apiUrl + item.ImageUrl)"
                                         width="60"
                                         height="60"
                                         style="object-fit:cover"
                                         class="rounded shadow-sm"
                                         onerror="this.src='/images/no-image.png'; this.onerror=null;" />
                                }
                                else
                                {
                                    <div class="bg-secondary text-white rounded d-flex align-items-center justify-content-center" style="width:60px; height:60px;">
                                        <i class="bi bi-image"></i>
                                    </div>
                                }
                            </td>
                            <td>
                                <div><strong>@item.Name</strong></div>
                                <small class="text-muted">EN: @item.Name_EN</small>
                            </td>
                            <td><small class="badge bg-light text-dark">@item.Latitude, @item.Longitude</small></td>
                            <td>
                                @if (item.HasDefaultAudio)
                                {
                                    <span class="badge bg-success" title="Audio mặc định từ mô tả">Default</span>
                                }
                                @if (item.HasProfessionalAudio)
                                {
                                    <span class="badge bg-warning text-dark" title="Audio chuyên nghiệp owner upload">Pro</span>
                                }
                            </td>
                            <td>
                                <div class="small fw-semibold">@item.QrCodeLabel</div>
                                <div class="d-grid gap-1 mt-1">
                                    <a asp-action="Qr" asp-route-id="@item.Id" class="btn btn-sm btn-outline-dark">Audio QR</a>
                                    <a asp-action="PaymentQr" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Payment QR</a>
                                </div>
                            </td>
                            <td class="text-center">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning">Edit</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger" onclick="return confirm('Are you sure?')">Delete</a>
                                @if (Context.Session.GetString("UserRole") == "Admin" && item.Status == "Pending")
                                {
                                    <a asp-action="Approve" asp-route-id="@item.Id" class="btn btn-sm btn-success">Approve</a>
                                    <a asp-action="Reject" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Reject</a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
