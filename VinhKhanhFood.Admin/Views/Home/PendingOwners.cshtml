@{
    ViewData["Title"] = "Duyệt Đơn Đăng Ký Owner";
}

<div class="container-fluid mt-4">
    <h2>⏳ Duyệt Đơn Đăng Ký Owner</h2>
    <hr />

    <div id="pendingOwners" class="row">
        <div class="col-md-12 text-center">
            <p class="text-muted">Đang tải dữ liệu...</p>
        </div>
    </div>
</div>

<!-- Modal xem chi tiết -->
<div class="modal fade" id="detailsModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Chi Tiết Đơn Đăng Ký</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="detailsBody">
                Đang tải...
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>

<script>
    const API_URL = 'http://localhost:5020/api';

    document.addEventListener('DOMContentLoaded', function() {
        loadPendingOwners();
    });

    function loadPendingOwners() {
        fetch(`${API_URL}/admin/pending-owners`)
            .then(response => response.json())
            .then(data => {
                const container = document.getElementById('pendingOwners');

                if (!data || data.length === 0) {
                    container.innerHTML = `
                        <div class="col-md-12">
                            <div class="alert alert-info">✅ Không có đơn đăng ký nào chờ duyệt</div>
                        </div>
                    `;
                    return;
                }

                let html = '';
                data.forEach(owner => {
                    html += `
                        <div class="col-md-6 mb-4">
                            <div class="card border-warning">
                                <div class="card-header bg-warning text-dark">
                                    <h5 class="mb-0">${owner.fullName}</h5>
                                </div>
                                <div class="card-body">
                                    <p><strong>👤 Username:</strong> ${owner.username}</p>
                                    <p><strong>🏪 Quán:</strong> ${owner.businessName}</p>
                                    <p><strong>📧 Email:</strong> ${owner.email}</p>
                                    <p><strong>📱 Điện thoại:</strong> ${owner.phoneNumber}</p>
                                    <p><strong>📅 Ngày Đăng:</strong> ${new Date(owner.registrationDate).toLocaleDateString('vi-VN')}</p>
                                </div>
                                <div class="card-footer">
                                    <button class="btn btn-sm btn-info" onclick="viewDetails(${owner.id})">👁️ Chi Tiết</button>
                                    <button class="btn btn-sm btn-success" onclick="approveOwner(${owner.id})">✅ Duyệt</button>
                                    <button class="btn btn-sm btn-danger" onclick="rejectOwner(${owner.id})">❌ Từ Chối</button>
                                </div>
                            </div>
                        </div>
                    `;
                });

                container.innerHTML = html;
            })
            .catch(error => {
                console.error('Error:', error);
                document.getElementById('pendingOwners').innerHTML = `
                    <div class="col-md-12">
                        <div class="alert alert-danger">❌ Không thể tải danh sách</div>
                    </div>
                `;
            });
    }

    function viewDetails(ownerId) {
        fetch(`${API_URL}/owner/${ownerId}`)
            .then(response => response.json())
            .then(owner => {
                let html = `
                    <div>
                        <h6>Thông Tin Cá Nhân</h6>
                        <p><strong>Tên:</strong> ${owner.fullName}</p>
                        <p><strong>Email:</strong> ${owner.email}</p>
                        <p><strong>SĐT:</strong> ${owner.phoneNumber}</p>
                        <p><strong>CMND/CCCD:</strong> ${owner.identificationNumber || 'N/A'}</p>
                        
                        <hr>
                        <h6>Thông Tin Quán</h6>
                        <p><strong>Tên Quán:</strong> ${owner.businessName}</p>
                        <p><strong>Mô Tả:</strong> ${owner.businessDescription || 'N/A'}</p>
                        <p><strong>Địa Chỉ:</strong> ${owner.address || 'N/A'}</p>
                        <p><strong>Mã Số Thuế:</strong> ${owner.taxNumber || 'N/A'}</p>
                    </div>
                `;
                document.getElementById('detailsBody').innerHTML = html;
                new bootstrap.Modal(document.getElementById('detailsModal')).show();
            });
    }

    function approveOwner(ownerId) {
        if (!confirm('Duyệt đơn đăng ký này?')) return;

        fetch(`${API_URL}/admin/approve-owner/${ownerId}`, { method: 'POST' })
            .then(response => {
                if (response.ok) {
                    alert('✅ Đã duyệt!');
                    loadPendingOwners();
                } else {
                    alert('❌ Lỗi!');
                }
            });
    }

    function rejectOwner(ownerId) {
        const reason = prompt('Nhập lý do từ chối:');
        if (!reason) return;

        fetch(`${API_URL}/admin/reject-owner/${ownerId}`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ reason })
        })
        .then(response => {
            if (response.ok) {
                alert('✅ Đã từ chối!');
                loadPendingOwners();
            } else {
                alert('❌ Lỗi!');
            }
        });
    }
</script>
