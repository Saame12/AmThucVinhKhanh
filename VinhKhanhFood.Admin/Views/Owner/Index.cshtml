@{
    ViewData["Title"] = "Owner Portal";
    var ownerName = Context.Session.GetString("UserName") ?? "Owner";
}

<div class="container-fluid pt-4">
    <div class="row justify-content-center">
        <div class="col-xl-10">
            <div class="card border-0 shadow-sm overflow-hidden mb-4">
                <div class="card-body p-4 p-lg-5" style="background:linear-gradient(135deg,#fff7ed 0%,#ffffff 60%,#ecfeff 100%);">
                    <div class="row align-items-center g-4">
                        <div class="col-lg-8">
                            <div class="text-uppercase small fw-semibold text-warning mb-2">Owner Workspace</div>
                            <h1 class="display-6 fw-bold mb-3">Chao mung @ownerName</h1>
                            <p class="text-muted mb-0">
                                Day la khu vuc rieng danh cho chu quan. Ban chi quan ly cac POI thuoc quyen cua minh, khong dung chung dashboard va chuc nang he thong cua admin.
                            </p>
                        </div>
                        <div class="col-lg-4 text-lg-end">
                            <a asp-controller="Poi" asp-action="Index" class="btn btn-warning btn-lg px-4">
                                <i class="bi bi-geo-alt"></i> Quan ly POI cua toi
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row g-4">
                <div class="col-md-6">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body p-4">
                            <div class="display-5 mb-3">📍</div>
                            <h4 class="fw-bold">My Locations</h4>
                            <p class="text-muted">
                                Xem, sua va cap nhat cac diem POI cua rieng ban. Danh sach nay da duoc loc theo Owner hien tai.
                            </p>
                            <a asp-controller="Poi" asp-action="Index" class="btn btn-outline-primary">Mo danh sach POI</a>
                        </div>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body p-4">
                            <div class="display-5 mb-3">➕</div>
                            <h4 class="fw-bold">Them POI moi</h4>
                            <p class="text-muted">
                                Tao POI moi voi hinh anh va mo ta da ngon ngu. Audio mac dinh cua app se duoc tao tu noi dung mo ta nay.
                            </p>
                            <a asp-controller="Poi" asp-action="Create" class="btn btn-outline-success">Them POI</a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm mt-4">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-3">Pham vi chuc nang cua Owner</h5>
                    <ul class="text-muted mb-0">
                        <li>Chi quan ly POI cua chinh chu quan dang dang nhap.</li>
                        <li>Khong truy cap Usage Dashboard, Payment History hay App Users cua admin.</li>
                        <li>Cac POI moi tao se vao trang thai cho duyet dung theo luong hien tai.</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>
