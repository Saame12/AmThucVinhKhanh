@using VinhKhanhFood.Admin.Models
@model AddFoodLocationViewModel
@{
    ViewData["Title"] = "Thêm Quán Ăn Mới";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <h2>➕ Thêm Quán Ăn Mới</h2>
            <hr />

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger">@ViewBag.Error</div>
            }

            <form method="post" asp-action="Create">
                <!-- Tiêu đề chính -->
                <div class="card mb-3">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0">📝 Thông Tin Cơ Bản</h5>
                    </div>
                    <div class="card-body">
                        <div class="form-group mb-3">
                            <label for="Name" class="form-label">Tên Quán (Tiếng Việt) <span class="text-danger">*</span></label>
                            <input type="text" id="Name" asp-for="Name" class="form-control" required placeholder="VD: Phở Vĩnh Khánh" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label for="Description" class="form-label">Mô Tả (Tiếng Việt)</label>
                            <textarea id="Description" asp-for="Description" class="form-control" rows="3" placeholder="Mô tả chi tiết về quán..."></textarea>
                            <button type="button" class="btn btn-sm btn-outline-info mt-2" onclick="speakText('Description')">
                                🔊 Nghe mô tả
                            </button>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label for="Name_EN" class="form-label">Tên Quán (English)</label>
                                <input type="text" id="Name_EN" asp-for="Name_EN" class="form-control" placeholder="VD: Vinh Khanh Pho" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label for="Name_ZH" class="form-label">Tên Quán (中文)</label>
                                <input type="text" id="Name_ZH" asp-for="Name_ZH" class="form-control" placeholder="VD: 文昌粉" />
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Vị trí trên bản đồ -->
                <div class="card mb-3">
                    <div class="card-header bg-info text-white">
                        <h5 class="mb-0">📍 Chọn Vị Trí Trên Bản Đồ</h5>
                    </div>
                    <div class="card-body">
                        <div id="map" style="width: 100%; height: 400px; border: 2px solid #ddd; border-radius: 5px; margin-bottom: 15px;"></div>
                        
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group mb-3">
                                    <label for="Latitude" class="form-label">Vĩ độ (Latitude) <span class="text-danger">*</span></label>
                                    <input type="number" id="Latitude" asp-for="Latitude" class="form-control" step="0.0001" required placeholder="VD: 10.7769" />
                                    <small class="form-text text-muted">Nhấp vào bản đồ để cập nhật</small>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group mb-3">
                                    <label for="Longitude" class="form-label">Kinh độ (Longitude) <span class="text-danger">*</span></label>
                                    <input type="number" id="Longitude" asp-for="Longitude" class="form-control" step="0.0001" required placeholder="VD: 106.6966" />
                                    <small class="form-text text-muted">Nhấp vào bản đồ để cập nhật</small>
                                </div>
                            </div>
                        </div>

                        <button type="button" class="btn btn-outline-info" onclick="goToMyLocation()">📍 Dùng Vị Trí Hiện Tại</button>
                    </div>
                </div>

                <!-- Hình ảnh & Audio -->
                <div class="card mb-3">
                    <div class="card-header bg-success text-white">
                        <h5 class="mb-0">📸 Hình Ảnh & Âm Thanh</h5>
                    </div>
                    <div class="card-body">
                        <div class="form-group mb-3">
                            <label for="ImageUrl" class="form-label">URL Hình Ảnh</label>
                            <input type="text" id="ImageUrl" asp-for="ImageUrl" class="form-control" placeholder="https://..." />
                            <small class="form-text text-muted">Link ảnh của quán</small>
                        </div>

                        <div class="form-group mb-3">
                            <label for="AudioUrl" class="form-label">URL Audio (Tiếng Việt)</label>
                            <input type="text" id="AudioUrl" asp-for="AudioUrl" class="form-control" placeholder="https://..." />
                            <small class="form-text text-muted">Link audio giới thiệu quán (Tiếng Việt)</small>
                        </div>
                    </div>
                </div>

                <!-- Nút hành động -->
                <div class="form-group">
                    <button type="submit" class="btn btn-primary btn-lg">
                        ✅ Gửi Yêu Cầu Thêm Quán
                    </button>
                    <a href="@Url.Action("Index", "Home")" class="btn btn-secondary btn-lg">
                        ❌ Hủy
                    </a>
                </div>

                <div class="alert alert-info mt-3">
                    <strong>⚠️ Lưu ý:</strong> Quán ăn của bạn sẽ chờ duyệt từ Admin trước khi công khai.
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Leaflet Map Library -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css" />
<script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js"></script>

<script>
    let map;
    let marker;
    let currentSpeech = null;

    // Initialize map
    document.addEventListener('DOMContentLoaded', function() {
        const defaultLat = document.getElementById('Latitude').value || 10.7769;
        const defaultLng = document.getElementById('Longitude').value || 106.6966;

        map = L.map('map').setView([defaultLat, defaultLng], 13);

        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '© OpenStreetMap contributors',
            maxZoom: 19
        }).addTo(map);

        // Add marker if coordinates exist
        if (defaultLat && defaultLng) {
            addMarker(defaultLat, defaultLng);
        }

        // Click on map to set location
        map.on('click', function(e) {
            const lat = e.latlng.lat;
            const lng = e.latlng.lng;
            document.getElementById('Latitude').value = lat.toFixed(6);
            document.getElementById('Longitude').value = lng.toFixed(6);
            addMarker(lat, lng);
        });
    });

    function addMarker(lat, lng) {
        if (marker) {
            map.removeLayer(marker);
        }
        marker = L.marker([lat, lng], {
            icon: L.icon({
                iconUrl: 'https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/images/marker-icon.png',
                shadowUrl: 'https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/images/marker-shadow.png',
                iconSize: [25, 41],
                iconAnchor: [12, 41],
                popupAnchor: [1, -34],
                shadowSize: [41, 41]
            })
        }).addTo(map).bindPopup(`📍 ${lat.toFixed(4)}, ${lng.toFixed(4)}`);
    }

    function goToMyLocation() {
        if (navigator.geolocation) {
            navigator.geolocation.getCurrentPosition(function(position) {
                const lat = position.coords.latitude;
                const lng = position.coords.longitude;
                document.getElementById('Latitude').value = lat.toFixed(6);
                document.getElementById('Longitude').value = lng.toFixed(6);
                map.setView([lat, lng], 15);
                addMarker(lat, lng);
            });
        } else {
            alert('Thiết bị của bạn không hỗ trợ định vị');
        }
    }

    // 🔊 Text-to-Speech Function
    function speakText(elementId) {
        const text = document.getElementById(elementId).value;

        if (!text) {
            alert('Vui lòng nhập nội dung trước');
            return;
        }

        // Stop previous speech
        if (currentSpeech) {
            speechSynthesis.cancel();
        }

        // Create utterance
        const utterance = new SpeechSynthesisUtterance(text);
        utterance.lang = 'vi-VN'; // Vietnamese
        utterance.rate = 0.9;
        utterance.pitch = 1;
        utterance.volume = 1;

        // Speak
        speechSynthesis.speak(utterance);

        // Button feedback
        const btn = event.target;
        const originalText = btn.innerHTML;
        btn.innerHTML = '⏸️ Dừng';
        btn.classList.remove('btn-outline-info');
        btn.classList.add('btn-warning');

        utterance.onend = function() {
            btn.innerHTML = originalText;
            btn.classList.remove('btn-warning');
            btn.classList.add('btn-outline-info');
            currentSpeech = null;
        };

        currentSpeech = utterance;
    }
</script>

<style>
    .card {
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        border: none;
        margin-bottom: 20px;
    }

    .card-header {
        border-radius: 0;
    }

    .form-control:focus {
        border-color: #667eea;
        box-shadow: 0 0 0 0.2rem rgba(102, 126, 234, 0.25);
    }

    .btn-lg {
        padding: 12px 30px;
        font-size: 16px;
    }
</style>
