@model List<VinhKhanhFood.Admin.Models.User>

@{
    ViewData["Title"] = "Quan ly User";
    var activeTravelerCount = ViewBag.ActiveTravelerCount is int count ? count : 0;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Quan sat nguoi dung app</h2>
    <span class="badge rounded-pill bg-success fs-6">Dang dung app: @activeTravelerCount</span>
</div>

@if (TempData["Error"] is string errorMessage)
{
    <div class="alert alert-danger">@errorMessage</div>
}

<table class="table table-bordered table-hover align-middle">
    <thead class="table-dark">
        <tr>
            <th>ID</th>
            <th>Username</th>
            <th>Ho ten</th>
            <th>Role</th>
            <th>Loai tai khoan</th>
            <th>Hien dien</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var u in Model)
        {
            var displayId = string.IsNullOrWhiteSpace(u.DisplayId) ? u.Id.ToString() : u.DisplayId;
            var isAdmin = string.Equals(u.Role, "Admin", StringComparison.OrdinalIgnoreCase);
            var isOwner = string.Equals(u.Role, "Owner", StringComparison.OrdinalIgnoreCase);
            var isVirtual = u.IsVirtual;

            <tr>
                <td>@displayId</td>
                <td>@u.Username</td>
                <td>@u.FullName</td>
                <td>
                    @if (isAdmin)
                    {
                        <span class="badge bg-danger">Admin</span>
                    }
                    else if (isOwner)
                    {
                        <span class="badge bg-primary">Owner</span>
                    }
                    else if (isVirtual)
                    {
                        <span class="badge bg-warning text-dark">Guest</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Traveler</span>
                    }
                </td>
                <td>
                    @if (isVirtual)
                    {
                        <span class="badge bg-light text-dark border">guid</span>
                    }
                    else
                    {
                        <span class="badge bg-light text-dark border">registered</span>
                    }
                </td>
                <td>
                    @if (u.OnlineStatus == "Online")
                    {
                        <span class="badge bg-success-subtle text-success border border-success-subtle">Online</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle">Offline</span>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
