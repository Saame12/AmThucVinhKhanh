<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:zxing="clr-namespace:ZXing.Net.Maui.Controls;assembly=ZXing.Net.MAUI.Controls"
             x:Class="VinhKhanhFood.App.ScanQrPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#08111F">

    <Grid>
        <zxing:CameraBarcodeReaderView x:Name="BarcodeReader"
                                       BarcodesDetected="OnBarcodesDetected"
                                       IsDetecting="True"
                                       HorizontalOptions="Fill"
                                       VerticalOptions="Fill" />

        <Grid WidthRequest="248"
              HeightRequest="248"
              HorizontalOptions="Center"
              VerticalOptions="Center">
            <Border Stroke="#7DD3FC"
                    StrokeThickness="3"
                    BackgroundColor="#22000000"
                    StrokeShape="RoundRectangle 28" />

            <Border Margin="0,-1,0,0"
                    HeightRequest="4"
                    BackgroundColor="#F97316"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 4"
                    VerticalOptions="Center" />
        </Grid>

        <Border Margin="20"
                Padding="14,12"
                BackgroundColor="#CC08111F"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 18"
                VerticalOptions="End">
            <Label x:Name="ScanStatusLabel"
                   FontSize="13"
                   FontAttributes="Bold"
                   HorizontalTextAlignment="Center"
                   TextColor="White" />
        </Border>
    </Grid>
</ContentPage>
