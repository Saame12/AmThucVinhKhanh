<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VinhKhanhFood.App.PaymentCheckoutPage"
             BackgroundColor="{StaticResource BackgroundPrimary}">

    <ScrollView>
        <VerticalStackLayout Padding="20,24,20,32" Spacing="20">
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                <Button Text="&#60;"
                        WidthRequest="46"
                        HeightRequest="46"
                        CornerRadius="23"
                        BackgroundColor="{StaticResource SurfaceLight}"
                        TextColor="{StaticResource TextPrimary}"
                        Clicked="OnBackClicked" />

                <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                    <Label x:Name="HeaderEyebrowLabel"
                           FontSize="12"
                           FontAttributes="Bold"
                           TextColor="#E85D2A" />
                    <Label x:Name="HeaderTitleLabel"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="{StaticResource TextPrimary}" />
                </VerticalStackLayout>
            </Grid>

            <Border BackgroundColor="{StaticResource SurfaceLight}"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 24"
                    Padding="18">
                <VerticalStackLayout Spacing="12">
                    <Label x:Name="PoiNameLabel"
                           FontSize="24"
                           FontAttributes="Bold"
                           TextColor="{StaticResource TextPrimary}" />
                    <Label x:Name="DescriptionLabel"
                           FontSize="14"
                           TextColor="{StaticResource TextSecondary}" />
                    <Label x:Name="AmountLabel"
                           FontSize="28"
                           FontAttributes="Bold"
                           TextColor="#F59E0B" />
                    <Image x:Name="PaymentQrImage"
                           HeightRequest="220"
                           WidthRequest="220"
                           HorizontalOptions="Center" />
                    <Label x:Name="QrCodeLabel"
                           HorizontalOptions="Center"
                           FontSize="13"
                           TextColor="{StaticResource TextSecondary}" />
                </VerticalStackLayout>
            </Border>

            <Border BackgroundColor="#FFF7ED"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 24"
                    Padding="18">
                <VerticalStackLayout Spacing="10">
                    <Label x:Name="HintLabel"
                           FontSize="14"
                           TextColor="{StaticResource TextSecondary}" />
                    <Button x:Name="ConfirmPaymentButton"
                            HeightRequest="48"
                            CornerRadius="16"
                            BackgroundColor="#F59E0B"
                            TextColor="White"
                            FontAttributes="Bold"
                            Clicked="OnConfirmPaymentClicked" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
