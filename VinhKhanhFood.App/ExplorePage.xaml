<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VinhKhanhFood.App.ExplorePage"
             BackgroundColor="{StaticResource BackgroundPrimary}">

    <ScrollView>
        <VerticalStackLayout Padding="20,24,20,32"
                             Spacing="22">
            <VerticalStackLayout Spacing="4">
                <Label x:Name="PageEyebrowLabel"
                       FontSize="14"
                       FontAttributes="Bold"
                       TextColor="#E85D2A" />
                <Label x:Name="PageTitleLabel"
                       FontSize="28"
                       FontAttributes="Bold"
                       TextColor="{StaticResource TextPrimary}" />
                <Label x:Name="PageSubtitleLabel"
                       FontSize="14"
                       TextColor="{StaticResource TextSecondary}" />
            </VerticalStackLayout>

            <Border BackgroundColor="#FFF3E8"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 28"
                    Padding="18">
                <VerticalStackLayout Spacing="16">
                    <Grid ColumnDefinitions="*,Auto"
                          ColumnSpacing="12">
                        <VerticalStackLayout Spacing="4">
                            <Label x:Name="WidgetTitleLabel"
                                   FontSize="22"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource TextPrimary}" />
                            <Label x:Name="WidgetSubtitleLabel"
                                   FontSize="13"
                                   TextColor="{StaticResource TextSecondary}" />
                        </VerticalStackLayout>

                        <Border Grid.Column="1"
                                BackgroundColor="White"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 16"
                                Padding="10,8"
                                VerticalOptions="Start">
                            <Label x:Name="TopBadgeLabel"
                                   FontSize="11"
                                   FontAttributes="Bold"
                                   TextColor="#E85D2A" />
                        </Border>
                    </Grid>

                    <CollectionView ItemsSource="{Binding HotLocations}"
                                    SelectionMode="Single"
                                    SelectionChanged="OnHotLocationSelected"
                                    HeightRequest="252">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Horizontal"
                                               ItemSpacing="14" />
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border WidthRequest="240"
                                        Padding="14"
                                        BackgroundColor="White"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 22">
                                    <VerticalStackLayout Spacing="12">
                                        <Border HeightRequest="132"
                                                BackgroundColor="#FFE7D6"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 18">
                                            <Image Source="{Binding ImageUrl}"
                                                   Aspect="AspectFill" />
                                        </Border>

                                        <VerticalStackLayout Spacing="6">
                                            <Label Text="{Binding DisplayName}"
                                                   FontSize="18"
                                                   FontAttributes="Bold"
                                                   TextColor="{StaticResource TextPrimary}" />
                                            <Label Text="{Binding DisplayDescription}"
                                                   FontSize="12"
                                                   MaxLines="3"
                                                   LineBreakMode="TailTruncation"
                                                   TextColor="{StaticResource TextSecondary}" />
                                        </VerticalStackLayout>
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>

            <VerticalStackLayout Spacing="14">
                <Label x:Name="NearbyListTitleLabel"
                       FontSize="20"
                       FontAttributes="Bold"
                       TextColor="{StaticResource TextPrimary}" />

                <CollectionView ItemsSource="{Binding Locations}"
                                SelectionMode="Single"
                                SelectionChanged="OnLocationSelected">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical"
                                           ItemSpacing="14" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="14"
                                    BackgroundColor="{StaticResource SurfaceLight}"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 22">
                                <Grid ColumnDefinitions="92,*,Auto"
                                      ColumnSpacing="14">
                                    <Border HeightRequest="92"
                                            WidthRequest="92"
                                            BackgroundColor="#FFE7D6"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 18">
                                        <Image Source="{Binding ImageUrl}"
                                               Aspect="AspectFill" />
                                    </Border>

                                    <VerticalStackLayout Grid.Column="1"
                                                         Spacing="6"
                                                         VerticalOptions="Center">
                                        <Label Text="{Binding DisplayName}"
                                               FontSize="18"
                                               FontAttributes="Bold"
                                               TextColor="{StaticResource TextPrimary}" />
                                        <Label Text="{Binding DisplayDescription}"
                                               FontSize="12"
                                               MaxLines="3"
                                               LineBreakMode="TailTruncation"
                                               TextColor="{StaticResource TextSecondary}" />
                                    </VerticalStackLayout>

                                    <Label Grid.Column="2"
                                           Text=">"
                                           FontSize="28"
                                           TextColor="#E85D2A"
                                           VerticalTextAlignment="Center" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
