<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VinhKhanhFood.App.ExplorePage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource BackgroundPrimary}">
    <Grid RowDefinitions="Auto, Auto, Auto, *">

        <!-- Header -->
        <VerticalStackLayout Grid.Row="0" Padding="20,40,20,15" Spacing="8">
            <HorizontalStackLayout>
                <Label Text="🍜 " FontSize="20" />
                <Label Text="Discover " FontSize="26" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" />
                <Label Text="Places" FontSize="26" FontAttributes="Bold" TextColor="{StaticResource Primary}" />
            </HorizontalStackLayout>
            <Label Text="Explore amazing food locations around you" FontSize="12" TextColor="{StaticResource TextSecondary}" />
        </VerticalStackLayout>

        <!-- Search Bar -->
        <Border Grid.Row="1" StrokeShape="RoundRectangle 12" BackgroundColor="{StaticResource SurfaceLight}" Stroke="{StaticResource Divider}" StrokeThickness="1" Margin="15,0,15,12" Padding="12,8">
            <Grid ColumnDefinitions="Auto, *">
                <Label Grid.Column="0" Text="🔍" FontSize="16" VerticalOptions="Center"/>
                <Entry Grid.Column="1" Placeholder="Search places..." TextColor="{StaticResource TextPrimary}" PlaceholderColor="{StaticResource TextTertiary}" BackgroundColor="Transparent" Margin="8,0"/>
            </Grid>
        </Border>

        <!-- Category Filter -->
        <ScrollView Grid.Row="2" Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
            <HorizontalStackLayout Spacing="8" Padding="15,5,15,15">
                <Border StrokeShape="RoundRectangle 20" BackgroundColor="{StaticResource Primary}" StrokeThickness="0" Padding="14,8">
                    <Label Text="🍽️  All" TextColor="White" FontAttributes="Bold" VerticalOptions="Center" FontSize="13"/>
                </Border>
                <Border StrokeShape="RoundRectangle 20" BackgroundColor="{StaticResource SurfaceLight}" Stroke="{StaticResource Divider}" StrokeThickness="1" Padding="14,8">
                    <Label Text="🦞  Seafood" TextColor="{StaticResource TextSecondary}" FontAttributes="Bold" VerticalOptions="Center" FontSize="13"/>
                </Border>
                <Border StrokeShape="RoundRectangle 20" BackgroundColor="{StaticResource SurfaceLight}" Stroke="{StaticResource Divider}" StrokeThickness="1" Padding="14,8">
                    <Label Text="🐌  Snails" TextColor="{StaticResource TextSecondary}" FontAttributes="Bold" VerticalOptions="Center" FontSize="13"/>
                </Border>
                <Border StrokeShape="RoundRectangle 20" BackgroundColor="{StaticResource SurfaceLight}" Stroke="{StaticResource Divider}" StrokeThickness="1" Padding="14,8">
                    <Label Text="🍲  Soup" TextColor="{StaticResource TextSecondary}" FontAttributes="Bold" VerticalOptions="Center" FontSize="13"/>
                </Border>
            </HorizontalStackLayout>
        </ScrollView>

        <!-- Food List - Grid Layout -->
        <CollectionView Grid.Row="3" 
                        ItemsSource="{Binding Locations}" 
                        Margin="12,0,12,0"
                        SelectionMode="Single"
                        SelectionChanged="OnLocationSelected">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="16" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border StrokeShape="RoundRectangle 16" StrokeThickness="0" BackgroundColor="{StaticResource SurfaceCard}" Shadow="Offset: 0, 2, Blur: 8, Color: #00000030">
                        <Grid RowDefinitions="120, Auto">

                            <Image Grid.Row="0" Source="{Binding ImageUrl}" Aspect="AspectFill" />

                            <!-- Overlay Badge -->
                            <Border Grid.Row="0" 
                                    StrokeShape="RoundRectangle 8" 
                                    BackgroundColor="{StaticResource Primary}" 
                                    StrokeThickness="0" 
                                    Padding="6,4"
                                    Margin="8,8,0,0"
                                    HorizontalOptions="Start"
                                    VerticalOptions="Start">
                                <Label Text="New" TextColor="White" FontSize="11" FontAttributes="Bold" />
                            </Border>

                            <!-- Info Section -->
                            <VerticalStackLayout Grid.Row="1" Padding="12" Spacing="6">
                                <Label Text="{Binding Name}" FontSize="14" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" LineBreakMode="TailTruncation" MaxLines="1" />

                                <!-- Rating Row -->
                                <HorizontalStackLayout Spacing="4" VerticalOptions="Center">
                                    <Label Text="⭐" FontSize="11" VerticalOptions="Center"/>
                                    <Label Text="4.8" TextColor="{StaticResource Primary}" FontSize="11" FontAttributes="Bold" VerticalOptions="Center"/>
                                    <Label Text="•" TextColor="{StaticResource TextTertiary}" Margin="2,0"/>
                                    <Label Text="(125)" TextColor="{StaticResource TextTertiary}" FontSize="10" VerticalOptions="Center"/>
                                </HorizontalStackLayout>

                                <!-- Description -->
                                <Label Text="{Binding Description}" TextColor="{StaticResource TextSecondary}" FontSize="11" MaxLines="1" LineBreakMode="TailTruncation" />

                                <!-- Distance -->
                                <HorizontalStackLayout Spacing="3" VerticalOptions="End">
                                    <Label Text="📍" FontSize="10" />
                                    <Label Text="250m away" TextColor="{StaticResource Primary}" FontSize="10" FontAttributes="Bold" />
                                </HorizontalStackLayout>
                            </VerticalStackLayout>

                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>
</ContentPage>