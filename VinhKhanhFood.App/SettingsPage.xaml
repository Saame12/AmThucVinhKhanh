<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VinhKhanhFood.App.SettingsPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource BackgroundPrimary}">

    <Grid>
        <ScrollView>
            <VerticalStackLayout Padding="20,50,20,30" Spacing="20">

                <VerticalStackLayout Spacing="5">
                    <Label Text="Settings" FontSize="32" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" />
                    <Label Text="Vinh Khanh Foodie Configuration" FontSize="14" TextColor="{StaticResource TextTertiary}" />
                </VerticalStackLayout>

                <Border StrokeShape="RoundRectangle 16" BackgroundColor="{StaticResource SurfaceLight}" StrokeThickness="0" Padding="20">
                    <VerticalStackLayout Spacing="20">
                        <VerticalStackLayout Spacing="2">
                            <Label Text="Audio &amp; Localization" FontSize="18" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" />
                            <Label Text="Core audio guide settings" FontSize="13" TextColor="{StaticResource TextTertiary}" />
                        </VerticalStackLayout>

                        <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="15">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnLanguageTapped" />
                            </Grid.GestureRecognizers>
                            <Label Grid.Column="0" 
                                   Text="&#xe894;" 
                                   FontFamily="MaterialIcons" 
                                   FontSize="24" 
                                   VerticalOptions="Center" 
                                   TextColor="{StaticResource Primary}" />
                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                <Label Text="Language" FontSize="16" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" />
                                <Label Text="Audio narration language" FontSize="13" TextColor="{StaticResource TextTertiary}" />
                            </VerticalStackLayout>
                            <HorizontalStackLayout Grid.Column="2" Spacing="8" VerticalOptions="Center">
                                <Label x:Name="LblCurrentLanguage" Text="VN Tiếng Việt" TextColor="{StaticResource TextSecondary}" FontSize="14" VerticalOptions="Center"/>
                                <Label Text=">" TextColor="{StaticResource TextSecondary}" FontSize="18" FontAttributes="Bold" VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                        </Grid>

                        <BoxView HeightRequest="1" Color="{StaticResource Divider}" />

                        <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="15">
                            <Label Grid.Column="0" 
                                   Text="&#xe425;" 
                                   FontFamily="MaterialIcons" 
                                   FontSize="24" 
                                   VerticalOptions="Center" 
                                   TextColor="{StaticResource Primary}" />
                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                <Label Text="Speech Speed" FontSize="16" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" />
                                <Label Text="Adjust narration speed" FontSize="13" TextColor="{StaticResource TextTertiary}" />
                            </VerticalStackLayout>
                            <Border Grid.Column="2" BackgroundColor="{StaticResource Primary}" StrokeShape="RoundRectangle 8" StrokeThickness="0" Padding="10,5" VerticalOptions="Center">
                                <Label x:Name="LblSpeedValue" Text="1.0x" TextColor="White" FontAttributes="Bold" FontSize="14" />
                            </Border>
                        </Grid>

                        <VerticalStackLayout Spacing="5">
                            <Slider x:Name="SpeedSlider" Minimum="0.5" Maximum="2.0" Value="1.0" MinimumTrackColor="{StaticResource Primary}" MaximumTrackColor="{StaticResource Divider}" ThumbColor="White" ValueChanged="OnSpeedSliderValueChanged" />
                            <Grid ColumnDefinitions="*, *, *">
                                <Label Grid.Column="0" Text="0.5x (Slow)" TextColor="{StaticResource TextTertiary}" FontSize="11" HorizontalOptions="Start" />
                                <Label Grid.Column="1" Text="1.0x (Normal)" TextColor="{StaticResource TextTertiary}" FontSize="11" HorizontalOptions="Center" />
                                <Label Grid.Column="2" Text="2.0x (Fast)" TextColor="{StaticResource TextTertiary}" FontSize="11" HorizontalOptions="End" />
                            </Grid>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <Border StrokeShape="RoundRectangle 16" BackgroundColor="{StaticResource SurfaceLight}" StrokeThickness="0" Padding="20">
                    <VerticalStackLayout Spacing="15">
                        <Label Text="About &amp; Account" FontSize="18" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" />

                        <Grid IsVisible="{Binding IsLoggedIn}" ColumnDefinitions="Auto, *, Auto" ColumnSpacing="15">
                            <Border WidthRequest="45" HeightRequest="45" StrokeShape="RoundRectangle 22" StrokeThickness="0">
                                <Image Source="user_avatar.png" Aspect="AspectFill" />
                            </Border>
                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                <Label Text="{Binding CurrentUserName}" FontAttributes="Bold" FontSize="15" TextColor="{StaticResource TextPrimary}" />
                                <Label Text="{Binding CurrentUserRole}" FontSize="12" TextColor="{StaticResource Primary}" />
                            </VerticalStackLayout>
                            <Button Grid.Column="2" Text="Logout" Clicked="OnLogoutClicked" TextColor="Red" BackgroundColor="Transparent" FontSize="12" />
                        </Grid>

                        <Button IsVisible="{Binding IsNotLoggedIn}" 
                Text="Login to Your Account" 
                Clicked="OnLoginClicked"
                BackgroundColor="{StaticResource Primary}" 
                TextColor="White" 
                FontAttributes="Bold" 
                CornerRadius="10" 
                HeightRequest="45" />

                        <BoxView HeightRequest="1" Color="{StaticResource Divider}" />

                        <HorizontalStackLayout Spacing="10">
                            <Label Text="Version Info:" TextColor="{StaticResource TextSecondary}" />
                            <Label Text="v1.0.0 - MVP Release" TextColor="{StaticResource TextPrimary}" FontAttributes="Bold" />
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <Grid x:Name="LanguageModal" BackgroundColor="#A0000000" IsVisible="False">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnCloseModalTapped" />
            </Grid.GestureRecognizers>

            <Border VerticalOptions="End" BackgroundColor="{StaticResource SurfaceLight}" StrokeShape="RoundRectangle 20,20,0,0" StrokeThickness="0">
                <VerticalStackLayout Padding="20,20,20,40" Spacing="15">

                    <Grid ColumnDefinitions="*, Auto">
                        <VerticalStackLayout Grid.Column="0">
                            <Label Text="Select Language" FontSize="20" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" />
                            <Label Text="Choose your preferred audio language" FontSize="14" TextColor="{StaticResource TextSecondary}" Margin="0,5,0,15" />
                        </VerticalStackLayout>
                        <Button Grid.Column="1" Text="✕" WidthRequest="32" HeightRequest="32" CornerRadius="16" Padding="0" BackgroundColor="{StaticResource Divider}" TextColor="{StaticResource TextSecondary}" FontAttributes="Bold" VerticalOptions="Start" Clicked="OnCloseModalTapped" />
                    </Grid>

                    <Border x:Name="OptVietnamese" BackgroundColor="#33FF9800" StrokeShape="RoundRectangle 12" StrokeThickness="0" Padding="15">
                        <Grid ColumnDefinitions="Auto, *, Auto">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer CommandParameter="vi" Tapped="OnLanguageSelected" />
                            </Grid.GestureRecognizers>
                            <Label Grid.Column="0" Text="VN" TextColor="{StaticResource TextSecondary}" FontSize="16" VerticalOptions="Center" Margin="0,0,10,0"/>
                            <Label Grid.Column="1" Text="Tiếng Việt" TextColor="{StaticResource TextPrimary}" FontSize="16" FontAttributes="Bold" VerticalOptions="Center" />
                            <Border Grid.Column="2" WidthRequest="20" HeightRequest="20" StrokeShape="RoundRectangle 10" BackgroundColor="Transparent" Stroke="{StaticResource TextSecondary}" StrokeThickness="2" VerticalOptions="Center" />
                        </Grid>
                    </Border>

                    <Border x:Name="OptEnglish" BackgroundColor="Transparent" StrokeShape="RoundRectangle 12" StrokeThickness="0" Padding="15">
                        <Grid ColumnDefinitions="Auto, *, Auto">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer CommandParameter="en" Tapped="OnLanguageSelected" />
                            </Grid.GestureRecognizers>
                            <Label Grid.Column="0" Text="GB" TextColor="{StaticResource TextSecondary}" FontSize="16" VerticalOptions="Center" Margin="0,0,10,0"/>
                            <Label Grid.Column="1" Text="English" TextColor="{StaticResource TextPrimary}" FontSize="16" FontAttributes="Bold" VerticalOptions="Center" />
                            <Border Grid.Column="2" WidthRequest="20" HeightRequest="20" StrokeShape="RoundRectangle 10" BackgroundColor="Transparent" Stroke="{StaticResource TextSecondary}" StrokeThickness="2" VerticalOptions="Center" />
                        </Grid>
                    </Border>

                    <Border x:Name="OptChinese" BackgroundColor="Transparent" StrokeShape="RoundRectangle 12" StrokeThickness="0" Padding="15">
                        <Grid ColumnDefinitions="Auto, *, Auto">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer CommandParameter="zh" Tapped="OnLanguageSelected" />
                            </Grid.GestureRecognizers>
                            <Label Grid.Column="0" Text="CN" TextColor="{StaticResource TextSecondary}" FontSize="16" VerticalOptions="Center" Margin="0,0,10,0"/>
                            <Label Grid.Column="1" Text="中文" TextColor="{StaticResource TextPrimary}" FontSize="16" FontAttributes="Bold" VerticalOptions="Center" />
                            <Border Grid.Column="2" WidthRequest="20" HeightRequest="20" StrokeShape="RoundRectangle 10" BackgroundColor="Transparent" Stroke="{StaticResource TextSecondary}" StrokeThickness="2" VerticalOptions="Center" />
                        </Grid>
                    </Border>

                    <Label Text="More languages coming soon in future updates" TextColor="{StaticResource TextTertiary}" FontSize="12" HorizontalOptions="Center" Margin="0,10,0,0"/>
                </VerticalStackLayout>
            </Border>
        </Grid>

    </Grid>
</ContentPage>
