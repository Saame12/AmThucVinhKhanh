<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VinhKhanhFood.App.SettingsPage"
             BackgroundColor="{StaticResource BackgroundPrimary}">

    <ScrollView>
        <VerticalStackLayout Padding="20,24,20,32"
                             Spacing="20">
            <Border BackgroundColor="#FFF3E8"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 28"
                    Padding="20">
                <VerticalStackLayout Spacing="8">
                    <Label x:Name="TitleLabel"
                           FontSize="28"
                           FontAttributes="Bold"
                           TextColor="{StaticResource TextPrimary}" />
                    <Label x:Name="SubtitleLabel"
                           FontSize="14"
                           TextColor="{StaticResource TextSecondary}" />
                </VerticalStackLayout>
            </Border>

            <Border BackgroundColor="{StaticResource SurfaceLight}"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 24"
                    Padding="18">
                <VerticalStackLayout Spacing="14">
                    <Label x:Name="LanguageSectionTitleLabel"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="{StaticResource TextPrimary}" />
                    <Label x:Name="LanguageSectionSubtitleLabel"
                           FontSize="13"
                           TextColor="{StaticResource TextSecondary}" />

                    <Grid ColumnDefinitions="*,Auto"
                          ColumnSpacing="12">
                        <VerticalStackLayout Spacing="4">
                            <Label x:Name="CurrentLanguageCaptionLabel"
                                   FontSize="12"
                                   FontAttributes="Bold"
                                   TextColor="#E85D2A" />
                            <Label x:Name="CurrentLanguageValueLabel"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource TextPrimary}" />
                        </VerticalStackLayout>

                        <Button x:Name="ChangeLanguageButton"
                                Grid.Column="1"
                                HeightRequest="46"
                                CornerRadius="16"
                                BackgroundColor="#E85D2A"
                                TextColor="White"
                                FontAttributes="Bold"
                                Clicked="OnChangeLanguageClicked" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <Border BackgroundColor="{StaticResource SurfaceLight}"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 24"
                    Padding="18">
                <VerticalStackLayout Spacing="10">
                    <Label x:Name="TravelerSectionTitleLabel"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="{StaticResource TextPrimary}" />
                    <Label x:Name="TravelerSectionSubtitleLabel"
                           FontSize="13"
                           TextColor="{StaticResource TextSecondary}" />
                    <Border BackgroundColor="#F8FAFC"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 18"
                            Padding="14">
                        <VerticalStackLayout Spacing="6">
                            <Label x:Name="GuidCaptionLabel"
                                   FontSize="12"
                                   FontAttributes="Bold"
                                   TextColor="#E85D2A" />
                            <Label x:Name="GuidValueLabel"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource TextPrimary}" />
                            <Label x:Name="GuidHintLabel"
                                   FontSize="12"
                                   TextColor="{StaticResource TextSecondary}" />
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>
            </Border>

            <Border BackgroundColor="{StaticResource SurfaceLight}"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 24"
                    Padding="18">
                <VerticalStackLayout Spacing="10">
                    <Label x:Name="VersionTitleLabel"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="{StaticResource TextPrimary}" />
                    <Label x:Name="VersionValueLabel"
                           FontSize="14"
                           TextColor="{StaticResource TextSecondary}" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
