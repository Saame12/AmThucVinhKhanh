<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VinhKhanhFood.App.SettingsPage"
             BackgroundColor="{StaticResource BackgroundPrimary}">

    <ScrollView>
        <VerticalStackLayout Padding="20,24,20,32"
                             Spacing="20">
            <Border BackgroundColor="#FFF3E8"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 28"
                    Padding="20">
                <VerticalStackLayout Spacing="8">
                    <Label x:Name="TitleLabel"
                           FontSize="28"
                           FontAttributes="Bold"
                           TextColor="{StaticResource TextPrimary}" />
                    <Label x:Name="SubtitleLabel"
                           FontSize="14"
                           TextColor="{StaticResource TextSecondary}" />
                </VerticalStackLayout>
            </Border>

            <Border BackgroundColor="{StaticResource SurfaceLight}"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 24"
                    Padding="18">
                <VerticalStackLayout Spacing="14">
                    <Label x:Name="LanguageSectionTitleLabel"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="{StaticResource TextPrimary}" />
                    <Label x:Name="LanguageSectionSubtitleLabel"
                           FontSize="13"
                           TextColor="{StaticResource TextSecondary}" />

                    <Grid ColumnDefinitions="*,Auto"
                          ColumnSpacing="12">
                        <VerticalStackLayout Spacing="4">
                            <Label x:Name="CurrentLanguageCaptionLabel"
                                   FontSize="12"
                                   FontAttributes="Bold"
                                   TextColor="#E85D2A" />
                            <Label x:Name="CurrentLanguageValueLabel"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource TextPrimary}" />
                        </VerticalStackLayout>

                        <Button x:Name="ChangeLanguageButton"
                                Grid.Column="1"
                                HeightRequest="46"
                                CornerRadius="16"
                                BackgroundColor="#E85D2A"
                                TextColor="White"
                                FontAttributes="Bold"
                                Clicked="OnChangeLanguageClicked" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <Border BackgroundColor="{StaticResource SurfaceLight}"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 24"
                    Padding="18">
                <VerticalStackLayout Spacing="10">
                    <Label x:Name="AccountSectionTitleLabel"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="{StaticResource TextPrimary}" />
                    <Label x:Name="AccountSectionSubtitleLabel"
                           FontSize="13"
                           TextColor="{StaticResource TextSecondary}" />

                    <Border BackgroundColor="#F8FAFC"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 18"
                            Padding="14">
                        <VerticalStackLayout Spacing="10">
                            <Label x:Name="AccountStatusLabel"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource TextPrimary}" />
                            <Label x:Name="AccountNameLabel"
                                   FontSize="13"
                                   TextColor="{StaticResource TextSecondary}" />
                            <HorizontalStackLayout Spacing="10">
                                <Button x:Name="LoginButton"
                                        HeightRequest="44"
                                        CornerRadius="14"
                                        BackgroundColor="#E85D2A"
                                        TextColor="White"
                                        FontAttributes="Bold"
                                        Clicked="OnLoginClicked" />
                                <Button x:Name="LogoutButton"
                                        HeightRequest="44"
                                        CornerRadius="14"
                                        BackgroundColor="{StaticResource BackgroundSecondary}"
                                        TextColor="{StaticResource TextPrimary}"
                                        FontAttributes="Bold"
                                        Clicked="OnLogoutClicked" />
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>
            </Border>

            <Border BackgroundColor="{StaticResource SurfaceLight}"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 24"
                    Padding="18">
                <VerticalStackLayout Spacing="10">
                    <Label x:Name="VipSectionTitleLabel"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="{StaticResource TextPrimary}" />
                    <Label x:Name="VipSectionSubtitleLabel"
                           FontSize="13"
                           TextColor="{StaticResource TextSecondary}" />
                    <Border BackgroundColor="#FFF7ED"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 18"
                            Padding="14">
                        <VerticalStackLayout Spacing="10">
                            <Label x:Name="VipStatusLabel"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource TextPrimary}" />
                            <Label x:Name="VipHintLabel"
                                   FontSize="13"
                                   TextColor="{StaticResource TextSecondary}" />
                            <Button x:Name="BuyVipButton"
                                    HeightRequest="44"
                                    CornerRadius="14"
                                    BackgroundColor="#F59E0B"
                                    TextColor="White"
                                    FontAttributes="Bold"
                                    Clicked="OnBuyVipClicked" />
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>
            </Border>

            <Border BackgroundColor="{StaticResource SurfaceLight}"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 24"
                    Padding="18">
                <VerticalStackLayout Spacing="10">
                    <Label x:Name="VersionTitleLabel"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="{StaticResource TextPrimary}" />
                    <Label x:Name="VersionValueLabel"
                           FontSize="14"
                           TextColor="{StaticResource TextSecondary}" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
