<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VinhKhanhFood.App.DetailPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource BackgroundPrimary}">

    <Grid RowDefinitions="*, Auto">

        <ScrollView Grid.Row="0">
            <VerticalStackLayout>

                <!-- Hero Image Section -->
                <Grid HeightRequest="300" BackgroundColor="{StaticResource Gray200}">
                    <Image Source="{Binding ImageUrl}" Aspect="AspectFill" />

                    <!-- Dark Overlay -->
                    <BoxView Color="#000000" Opacity="0.2" />

                    <!-- Back Button -->
                    <Button Text="←" 
                            FontSize="22" 
                            FontAttributes="Bold" 
                            TextColor="White" 
                            BackgroundColor="{StaticResource Gray400}" 
                            CornerRadius="20" 
                            WidthRequest="44" 
                            HeightRequest="44" 
                            HorizontalOptions="Start" 
                            VerticalOptions="Start" 
                            Margin="16,24,0,0" 
                            Padding="0"
                            Clicked="OnBackButtonClicked" />

                    <!-- Share Button -->
                    <Button Text="🔗" 
                            FontSize="18" 
                            TextColor="White" 
                            BackgroundColor="{StaticResource Primary}" 
                            CornerRadius="20" 
                            WidthRequest="44" 
                            HeightRequest="44" 
                            HorizontalOptions="End" 
                            VerticalOptions="Start" 
                            Margin="0,24,16,0" 
                            Padding="0" />
                </Grid>

                <!-- Main Content -->
                <VerticalStackLayout Padding="20" Spacing="16" BackgroundColor="{StaticResource BackgroundPrimary}">

                    <!-- Title and Rating -->
                    <VerticalStackLayout Spacing="8">
                        <Label Text="{Binding Name}" FontSize="28" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" />
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="⭐" FontSize="16" VerticalOptions="Center" />
                            <Label Text="4.7" TextColor="{StaticResource Primary}" FontSize="15" FontAttributes="Bold" VerticalOptions="Center" />
                            <Label Text="•" TextColor="{StaticResource TextTertiary}" VerticalOptions="Center" />
                            <Label Text="Category: Seafood &amp; Snails" TextColor="{StaticResource TextSecondary}" FontSize="13" VerticalOptions="Center" />
                        </HorizontalStackLayout>
                    </VerticalStackLayout>

                    <!-- Info Cards -->
                    <VerticalStackLayout Spacing="10">
                        <!-- Location -->
                        <Border StrokeShape="RoundRectangle 12" BackgroundColor="{StaticResource SurfaceLight}" Stroke="{StaticResource Divider}" StrokeThickness="1" Padding="14,12">
                            <HorizontalStackLayout Spacing="12" VerticalOptions="Center">
                                <Label Text="📍" FontSize="18" TextColor="{StaticResource Primary}" />
                                <VerticalStackLayout Spacing="2" VerticalOptions="Center">
                                    <Label Text="Location" TextColor="{StaticResource TextTertiary}" FontSize="11" />
                                    <Label Text="123 Vĩnh Khánh, Quận 4" TextColor="{StaticResource TextPrimary}" FontSize="13" FontAttributes="Bold" />
                                </VerticalStackLayout>
                            </HorizontalStackLayout>
                        </Border>

                        <!-- Hours -->
                        <Border StrokeShape="RoundRectangle 12" BackgroundColor="{StaticResource SurfaceLight}" Stroke="{StaticResource Divider}" StrokeThickness="1" Padding="14,12">
                            <HorizontalStackLayout Spacing="12" VerticalOptions="Center">
                                <Label Text="🕒" FontSize="18" TextColor="{StaticResource Primary}" />
                                <VerticalStackLayout Spacing="2" VerticalOptions="Center">
                                    <Label Text="Opening Hours" TextColor="{StaticResource TextTertiary}" FontSize="11" />
                                    <Label Text="5:00 PM - 11:30 PM" TextColor="{StaticResource TextPrimary}" FontSize="13" FontAttributes="Bold" />
                                </VerticalStackLayout>
                            </HorizontalStackLayout>
                        </Border>

                        <!-- Phone -->
                        <Border StrokeShape="RoundRectangle 12" BackgroundColor="{StaticResource SurfaceLight}" Stroke="{StaticResource Divider}" StrokeThickness="1" Padding="14,12">
                            <HorizontalStackLayout Spacing="12" VerticalOptions="Center">
                                <Label Text="📞" FontSize="18" TextColor="{StaticResource Primary}" />
                                <VerticalStackLayout Spacing="2" VerticalOptions="Center">
                                    <Label Text="Phone" TextColor="{StaticResource TextTertiary}" FontSize="11" />
                                    <Label Text="+84 90 456 7788" TextColor="{StaticResource TextPrimary}" FontSize="13" FontAttributes="Bold" />
                                </VerticalStackLayout>
                            </HorizontalStackLayout>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Audio Section -->
                    <Border StrokeShape="RoundRectangle 14" BackgroundColor="{StaticResource SurfaceLight}" Stroke="{StaticResource Divider}" StrokeThickness="1" Padding="16,14">
                        <VerticalStackLayout Spacing="12">
                            <Label Text="🎙️  Audio Guide" TextColor="{StaticResource TextPrimary}" FontSize="16" FontAttributes="Bold" />

                            <Grid ColumnDefinitions="Auto, *" ColumnSpacing="12">
                                <Button x:Name="BtnPlayAudio" 
                                        Grid.Column="0" 
                                        Text="▶" 
                                        TextColor="White" 
                                        BackgroundColor="{StaticResource Primary}" 
                                        CornerRadius="24" 
                                        WidthRequest="48" 
                                        HeightRequest="48" 
                                        FontSize="18" 
                                        Padding="0" 
                                        VerticalOptions="Center"
                                        Clicked="OnToggleAudioClicked"/>

                                <VerticalStackLayout Grid.Column="1" Spacing="6" VerticalOptions="Center">
                                    <Label x:Name="LblAudioStatus" Text="Listen to Introduction" TextColor="{StaticResource TextPrimary}" FontAttributes="Bold" FontSize="13" />
                                    <ProgressBar x:Name="AudioProgressBar" 
                                                 Progress="0" 
                                                 ProgressColor="{StaticResource Primary}" 
                                                 BackgroundColor="{StaticResource Gray200}"
                                                 HeightRequest="4"/>
                                </VerticalStackLayout>
                            </Grid>
                        </VerticalStackLayout>
                    </Border>

                    <!-- About Section -->
                    <VerticalStackLayout Spacing="10">
                        <Label Text="📖  About" TextColor="{StaticResource TextPrimary}" FontSize="18" FontAttributes="Bold" />
                        <Label Text="{Binding Description}" 
                               TextColor="{StaticResource TextSecondary}" 
                               LineHeight="1.6" 
                               FontSize="14"
                               Margin="0,0,0,8" />
                    </VerticalStackLayout>

                    <!-- Highlights -->
                    <VerticalStackLayout Spacing="10">
                        <Label Text="✨  Highlights" TextColor="{StaticResource TextPrimary}" FontSize="18" FontAttributes="Bold" />
                        <VerticalStackLayout Spacing="6">
                            <HorizontalStackLayout Spacing="8">
                                <Label Text="✓" TextColor="{StaticResource Secondary}" FontSize="14" FontAttributes="Bold" />
                                <Label Text="Fresh seafood daily" TextColor="{StaticResource TextSecondary}" FontSize="13" />
                            </HorizontalStackLayout>
                            <HorizontalStackLayout Spacing="8">
                                <Label Text="✓" TextColor="{StaticResource Secondary}" FontSize="14" FontAttributes="Bold" />
                                <Label Text="Traditional recipes since 1995" TextColor="{StaticResource TextSecondary}" FontSize="13" />
                            </HorizontalStackLayout>
                            <HorizontalStackLayout Spacing="8">
                                <Label Text="✓" TextColor="{StaticResource Secondary}" FontSize="14" FontAttributes="Bold" />
                                <Label Text="Family-friendly atmosphere" TextColor="{StaticResource TextSecondary}" FontSize="13" />
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>

        <!-- Bottom Action Bar -->
        <Grid Grid.Row="1" ColumnDefinitions="*, *" ColumnSpacing="12" Padding="16,12,16,20" BackgroundColor="{StaticResource BackgroundPrimary}">
            <Button Grid.Column="0" 
                    Text="🧭 Get Directions" 
                    BackgroundColor="{StaticResource Primary}" 
                    TextColor="White" 
                    FontAttributes="Bold" 
                    CornerRadius="10" 
                    HeightRequest="52"
                    FontSize="14"
                    Clicked="OnGetDirectionsClicked"/>
            <Button Grid.Column="1" 
                    Text="📞 Call Store" 
                    BackgroundColor="{StaticResource Gray300}" 
                    TextColor="{StaticResource TextPrimary}" 
                    FontAttributes="Bold" 
                    CornerRadius="10" 
                    HeightRequest="52"
                    FontSize="14"
                    BorderColor="#3A3A3A"
                    BorderWidth="1"/>
        </Grid>

    </Grid>
</ContentPage>