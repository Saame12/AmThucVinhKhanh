<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VinhKhanhFood.App.DetailPage"
             BackgroundColor="{StaticResource BackgroundPrimary}">

    <ScrollView>
        <VerticalStackLayout Padding="20,24,20,32" Spacing="20">
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                <Button x:Name="BackButton"
                        Text="&#60;"
                        WidthRequest="46"
                        HeightRequest="46"
                        CornerRadius="23"
                        BackgroundColor="{StaticResource SurfaceLight}"
                        TextColor="{StaticResource TextPrimary}"
                        HorizontalOptions="Start"
                        Clicked="OnBackClicked" />

                <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                    <Label x:Name="HeaderEyebrowLabel"
                           FontSize="12"
                           FontAttributes="Bold"
                           TextColor="#E85D2A" />
                    <Label x:Name="HeaderTitleLabel"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="{StaticResource TextPrimary}" />
                </VerticalStackLayout>
            </Grid>

            <Grid RowDefinitions="Auto,Auto">
                <Border StrokeThickness="0"
                        StrokeShape="RoundRectangle 28">
                    <Image x:Name="HeroImage"
                           HeightRequest="280"
                           Aspect="AspectFill" />
                </Border>

                <Border Margin="16,-34,16,0"
                        Grid.Row="1"
                        BackgroundColor="#FFFDF9"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 24"
                        Padding="16">
                    <VerticalStackLayout Spacing="8">
                        <Label x:Name="NameLabel"
                               FontSize="28"
                               FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}" />
                        <Label x:Name="DescriptionLabel"
                               FontSize="14"
                               TextColor="{StaticResource TextSecondary}" />
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <Border StrokeThickness="0"
                    BackgroundColor="{StaticResource SurfaceLight}"
                    StrokeShape="RoundRectangle 24"
                    Padding="18">
                <VerticalStackLayout Spacing="14">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <VerticalStackLayout Spacing="4">
                            <Label x:Name="AudioSectionTitleLabel"
                                   FontSize="20"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource TextPrimary}" />
                            <Label x:Name="AudioStatusLabel"
                                   FontSize="13"
                                   TextColor="{StaticResource TextSecondary}" />
                        </VerticalStackLayout>

                        <Border Grid.Column="1"
                                BackgroundColor="#EFF6FF"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 14"
                                Padding="10,8"
                                VerticalOptions="Start">
                            <Label x:Name="GuideBadgeLabel"
                                   FontSize="11"
                                   FontAttributes="Bold"
                                   TextColor="#2563EB" />
                        </Border>
                    </Grid>

                    <HorizontalStackLayout Spacing="12">
                        <Button x:Name="PlayAudioButton"
                                TextColor="White"
                                BackgroundColor="#E85D2A"
                                CornerRadius="16"
                                HeightRequest="48"
                                HorizontalOptions="Fill"
                                Clicked="OnPlayAudioClicked" />
                        <Button x:Name="CancelAudioButton"
                                TextColor="{StaticResource TextPrimary}"
                                BackgroundColor="{StaticResource BackgroundSecondary}"
                                CornerRadius="16"
                                HeightRequest="48"
                                HorizontalOptions="Fill"
                                Clicked="OnCancelAudioClicked" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>

            <Border x:Name="ProfessionalAudioCard"
                    StrokeThickness="0"
                    BackgroundColor="#FFF7ED"
                    StrokeShape="RoundRectangle 24"
                    Padding="18">
                <VerticalStackLayout Spacing="14">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <VerticalStackLayout Spacing="4">
                            <Label x:Name="ProfessionalAudioTitleLabel"
                                   FontSize="20"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource TextPrimary}" />
                            <Label x:Name="ProfessionalAudioStatusLabel"
                                   FontSize="13"
                                   TextColor="{StaticResource TextSecondary}" />
                        </VerticalStackLayout>

                        <Border BackgroundColor="#FEF3C7"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 14"
                                Padding="10,8"
                                VerticalOptions="Start">
                            <Label x:Name="VipBadgeLabel"
                                   FontSize="11"
                                   FontAttributes="Bold"
                                   TextColor="#B45309" />
                        </Border>
                    </Grid>

                    <Button x:Name="PlayProfessionalAudioButton"
                            TextColor="White"
                            BackgroundColor="#F59E0B"
                            CornerRadius="16"
                            HeightRequest="48"
                            Clicked="OnPlayProfessionalAudioClicked" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
