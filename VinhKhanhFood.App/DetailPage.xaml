<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VinhKhanhFood.App.DetailPage"
             BackgroundColor="{StaticResource BackgroundPrimary}">

    <ScrollView>
        <VerticalStackLayout Padding="20,24,20,32" Spacing="20">
            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                <Button x:Name="BackButton"
                        Text="&#60;"
                        WidthRequest="46"
                        HeightRequest="46"
                        CornerRadius="23"
                        BackgroundColor="{StaticResource SurfaceLight}"
                        TextColor="{StaticResource TextPrimary}"
                        HorizontalOptions="Start"
                        Clicked="OnBackClicked" />

                <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                    <Label Text="POI Detail"
                           FontSize="12"
                           FontAttributes="Bold"
                           TextColor="#E85D2A" />
                    <Label Text="Audio and QR Experience"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="{StaticResource TextPrimary}" />
                </VerticalStackLayout>

                <Border Grid.Column="2"
                        BackgroundColor="#FFF1E8"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 14"
                        Padding="10,8"
                        VerticalOptions="Center">
                    <Label Text="{Binding QrCodeLabel}"
                           FontSize="10"
                           FontAttributes="Bold"
                           TextColor="#E85D2A" />
                </Border>
            </Grid>

            <Grid RowDefinitions="Auto,Auto">
                <Border StrokeThickness="0"
                        StrokeShape="RoundRectangle 28">
                    <Image x:Name="HeroImage"
                           HeightRequest="280"
                           Aspect="AspectFill" />
                </Border>

                <Border Margin="16,-34,16,0"
                        Grid.Row="1"
                        BackgroundColor="#FFFDF9"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 24"
                        Padding="16">
                    <VerticalStackLayout Spacing="8">
                        <Label x:Name="NameLabel"
                               FontSize="28"
                               FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}" />
                        <Label x:Name="DescriptionLabel"
                               FontSize="14"
                               TextColor="{StaticResource TextSecondary}" />
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <Border StrokeThickness="0"
                    BackgroundColor="{StaticResource SurfaceLight}"
                    StrokeShape="RoundRectangle 24"
                    Padding="18">
                <VerticalStackLayout Spacing="14">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <VerticalStackLayout Spacing="4">
                            <Label x:Name="AudioSectionTitleLabel"
                                   FontSize="20"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource TextPrimary}" />
                            <Label x:Name="AudioStatusLabel"
                                   FontSize="13"
                                   TextColor="{StaticResource TextSecondary}" />
                        </VerticalStackLayout>

                        <Border Grid.Column="1"
                                BackgroundColor="#EFF6FF"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 14"
                                Padding="10,8"
                                VerticalOptions="Start">
                            <Label Text="GUIDE"
                                   FontSize="11"
                                   FontAttributes="Bold"
                                   TextColor="#2563EB" />
                        </Border>
                    </Grid>

                    <HorizontalStackLayout Spacing="12">
                        <Button x:Name="PlayAudioButton"
                                TextColor="White"
                                BackgroundColor="#E85D2A"
                                CornerRadius="16"
                                HeightRequest="48"
                                HorizontalOptions="Fill"
                                Clicked="OnPlayAudioClicked" />
                        <Button x:Name="CancelAudioButton"
                                TextColor="{StaticResource TextPrimary}"
                                BackgroundColor="{StaticResource BackgroundSecondary}"
                                CornerRadius="16"
                                HeightRequest="48"
                                HorizontalOptions="Fill"
                                Clicked="OnCancelAudioClicked" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>

            <Border StrokeThickness="0"
                    BackgroundColor="{StaticResource SurfaceLight}"
                    StrokeShape="RoundRectangle 24"
                    Padding="18">
                <VerticalStackLayout Spacing="14">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <VerticalStackLayout Spacing="4">
                            <Label x:Name="QrTitleLabel"
                                   FontSize="20"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource TextPrimary}" />
                            <Label x:Name="QrInstructionLabel"
                                   FontSize="13"
                                   TextColor="{StaticResource TextSecondary}" />
                        </VerticalStackLayout>

                        <Border Grid.Column="1"
                                BackgroundColor="#ECFDF5"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 14"
                                Padding="10,8"
                                VerticalOptions="Start">
                            <Label Text="SCAN"
                                   FontSize="11"
                                   FontAttributes="Bold"
                                   TextColor="#059669" />
                        </Border>
                    </Grid>

                    <Border Stroke="{StaticResource Divider}"
                            StrokeShape="RoundRectangle 22"
                            BackgroundColor="{StaticResource BackgroundPrimary}"
                            Padding="18">
                        <VerticalStackLayout Spacing="14">
                            <Image Source="{Binding QrCodeImageUrl}"
                                   WidthRequest="190"
                                   HeightRequest="190"
                                   HorizontalOptions="Center"
                                   Aspect="AspectFit" />
                            <Label Text="{Binding QrCodeLabel}"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   HorizontalTextAlignment="Center"
                                   TextColor="#E85D2A" />
                            <Label Text="{Binding QrAudioUri}"
                                   FontSize="12"
                                   HorizontalTextAlignment="Center"
                                   TextColor="{StaticResource TextSecondary}" />
                        </VerticalStackLayout>
                    </Border>

                    <Button x:Name="CopyQrButton"
                            CornerRadius="16"
                            HeightRequest="48"
                            BackgroundColor="{StaticResource BackgroundSecondary}"
                            TextColor="{StaticResource TextPrimary}"
                            Clicked="OnCopyQrClicked" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
