<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="VinhKhanhFood.App.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:VinhKhanhFood.App"
    Shell.FlyoutBehavior="Disabled"
    Shell.NavBarIsVisible="False"
    TabBarBackgroundColor="#1A1A1A"
    TabBarTitleColor="#C41E3A"
    TabBarUnselectedColor="#808080">

    <TabBar>
        <Tab x:Name="MapTab" Route="MapTab" Title="Map" Icon="dotnet_bot.png">
            <ShellContent ContentTemplate="{DataTemplate local:MainPage}" />
        </Tab>

        <Tab x:Name="ExploreTab" Route="ExploreTab" Title="Explore" Icon="dotnet_bot.png">
            <ShellContent ContentTemplate="{DataTemplate local:ExplorePage}" />
        </Tab>

        <Tab x:Name="ScanTab" Route="ScanTab" Title="Scan" Icon="dotnet_bot.png">
            <ShellContent ContentTemplate="{DataTemplate local:ScanQrPage}" />
        </Tab>

        <Tab x:Name="SettingsTab" Route="SettingsTab" Title="Settings" Icon="dotnet_bot.png">
            <ShellContent ContentTemplate="{DataTemplate local:SettingsPage}" />
        </Tab>
    </TabBar>

</Shell>
